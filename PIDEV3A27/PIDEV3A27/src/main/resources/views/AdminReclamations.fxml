<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml" 
      fx:controller="controllers.AdminReclamationsController"
      spacing="20" styleClass="admin-container">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Gestion des Réclamations" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Rafraîchir" onAction="#refresh" styleClass="refresh-btn"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <TextField fx:id="searchField" promptText="Rechercher par utilisateur, objet ou statut..." 
                   HBox.hgrow="ALWAYS" style="-fx-padding: 8; -fx-background-radius: 5; -fx-border-color: #cbd5e0; -fx-border-radius: 5;"/>
        <ComboBox fx:id="sortComboBox" promptText="Trier par Priorité" style="-fx-padding: 4;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
        <content>
            <FlowPane fx:id="reclamationsGrid" hgap="25" vgap="25" alignment="TOP_LEFT">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
            </FlowPane>
        </content>
    </ScrollPane>

</VBox>
