<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.ReclamationCardController"
      spacing="10"
      style="-fx-background-color: white; 
             -fx-background-radius: 15; 
             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); 
             -fx-padding: 20; 
             -fx-border-color: #f0f0f0; 
             -fx-border-radius: 15; 
             -fx-border-width: 1;"
      prefWidth="300" maxWidth="300">

    <HBox alignment="CENTER_LEFT" spacing="10">
        <StackPane fx:id="iconContainer" style="-fx-background-color: #e3f2fd; -fx-background-radius: 10; -fx-padding: 8;">
            <Label fx:id="typeEmoji" text="📝" style="-fx-font-size: 20px;"/>
        </StackPane>
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label fx:id="typeLabel" text="Objet de la réclamation" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2c3e50;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label fx:id="dateLabel" text="12 Oct 2023" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                <Label fx:id="urgenceLabel" text="HIGH" style="-fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: #e53e3e; -fx-padding: 2 6; -fx-background-radius: 4;"/>
            </HBox>
        </VBox>
        <Label fx:id="statutLabel" text="En attente" 
               style="-fx-background-color: #fbd38d; -fx-text-fill: #744210; -fx-padding: 4 10; -fx-background-radius: 8; -fx-font-size: 11px; -fx-font-weight: bold;"/>
    </HBox>

    <Separator style="-fx-opacity: 0.5;"/>

    <Label fx:id="descriptionLabel" text="Description de la réclamation..." 
           wrapText="true" minHeight="60" alignment="TOP_LEFT"
           style="-fx-text-fill: #555; -fx-font-size: 13px; -fx-line-spacing: 2;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="editBtn" text="Modifier" onAction="#handleEdit"
                style="-fx-background-color: #077bff; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 6 12; -fx-font-size: 12px;"/>
        <Button fx:id="deleteBtn" text="Supprimer" onAction="#handleDelete"
                style="-fx-background-color: #342fd3; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 6 12; -fx-font-size: 12px;"/>
    </HBox>

</VBox>
