<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns:fx="http://javafx.com/fxml" 
      fx:controller="controllers.UserCardController"
      spacing="12" 
      style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 20; -fx-min-width: 280; -fx-max-width: 280;">

    <HBox spacing="15" alignment="CENTER_LEFT">
        <StackPane>
            <Circle radius="25" fill="#5646c5"/>
            <Label fx:id="initialsLabel" text="JD" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px;"/>
        </StackPane>
        <VBox spacing="2">
            <Label fx:id="nameLabel" text="John Doe" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label fx:id="roleLabel" text="Patient" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-background-color: #ecf0f1; -fx-padding: 3 8; -fx-background-radius: 10;"/>
        </VBox>
    </HBox>

    <VBox spacing="8" style="-fx-padding: 5 0;">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="📧" style="-fx-font-size: 14px;"/>
            <Label fx:id="emailLabel" text="john.doe@example.com" style="-fx-font-size: 13px; -fx-text-fill: #34495e;"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="📞" style="-fx-font-size: 14px;"/>
            <Label fx:id="phoneLabel" text="+216 22 123 456" style="-fx-font-size: 13px; -fx-text-fill: #34495e;"/>
        </HBox>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0; -fx-border-color: #f1f2f6; -fx-border-width: 1 0 0 0;">
        <Button text="Modifier" onAction="#handleEdit" 
                style="-fx-background-color: #f1f2f6; -fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>
        <Button text="Supprimer" onAction="#handleDelete" 
                style="-fx-background-color: #fee2e2; -fx-text-fill: #dc2626; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>
    </HBox>

</VBox>
