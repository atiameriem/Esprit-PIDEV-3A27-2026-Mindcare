<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="25" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.StatistiquesController"
      style="-fx-background-color: #f4f7fa; -fx-padding: 30;">

    <!-- HEADER -->
    <HBox spacing="15" alignment="CENTER_LEFT"
          style="-fx-background-color: white; -fx-padding: 20 25; -fx-background-radius: 14;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 12, 0, 0, 4);">
        <StackPane style="-fx-background-color: #1a73e8; -fx-background-radius: 10;
                          -fx-min-width: 50; -fx-min-height: 50; -fx-max-width: 50; -fx-max-height: 50;">
            <Label text="📊" style="-fx-font-size: 24px;"/>
        </StackPane>
        <VBox spacing="3">
            <Label text="Statistiques de Consultation"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #202124;"/>
            <Label fx:id="psychoNameLabel" text="Chargement..."
                   style="-fx-font-size: 13px; -fx-text-fill: #5f6368;"/>
        </VBox>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="🔄  Actualiser" onAction="#handleRefresh"
                style="-fx-background-color: #e8f0fe; -fx-text-fill: #1a73e8; -fx-font-weight: bold;
                       -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;
                       -fx-border-color: #c5d8fb; -fx-border-radius: 8;"/>
    </HBox>

    <!-- KPI CARDS ROW -->
    <HBox spacing="20">

        <VBox spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER"
              style="-fx-background-color: white; -fx-padding: 28; -fx-background-radius: 14;
                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 12, 0, 0, 4);">
            <Label text="📅" style="-fx-font-size: 30px;"/>
            <Label fx:id="totalRdvLabel" text="0"
                   style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: #1a73e8;"/>
            <Label text="Total Rendez-vous"
                   style="-fx-font-size: 13px; -fx-text-fill: #5f6368;"/>
        </VBox>

        <VBox spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER"
              style="-fx-background-color: white; -fx-padding: 28; -fx-background-radius: 14;
                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 12, 0, 0, 4);">
            <Label text="🗓️" style="-fx-font-size: 30px;"/>
            <Label fx:id="rdvMoisLabel" text="0"
                   style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: #34a853;"/>
            <Label text="Ce mois-ci"
                   style="-fx-font-size: 13px; -fx-text-fill: #5f6368;"/>
        </VBox>

        <VBox spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER"
              style="-fx-background-color: white; -fx-padding: 28; -fx-background-radius: 14;
                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 12, 0, 0, 4);">
            <Label text="📄" style="-fx-font-size: 30px;"/>
            <Label fx:id="totalCrLabel" text="0"
                   style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: #fbbc04;"/>
            <Label text="Comptes-rendus"
                   style="-fx-font-size: 13px; -fx-text-fill: #5f6368;"/>
        </VBox>

        <VBox spacing="8" HBox.hgrow="ALWAYS" alignment="CENTER"
              style="-fx-background-color: white; -fx-padding: 28; -fx-background-radius: 14;
                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 12, 0, 0, 4);">
            <Label text="👥" style="-fx-font-size: 30px;"/>
            <Label fx:id="patientsLabel" text="0"
                   style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: #ea4335;"/>
            <Label text="Patients suivis"
                   style="-fx-font-size: 13px; -fx-text-fill: #5f6368;"/>
        </VBox>

    </HBox>

    <!-- LISTE DYNAMIQUE (remplie par le controller) -->
    <VBox spacing="0" VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 14;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 12, 0, 0, 4);">

        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-padding: 18 25 14 25; -fx-border-color: transparent transparent #f1f3f4 transparent; -fx-border-width: 0 0 1 0;">
            <Label text="📋" style="-fx-font-size: 18px;"/>
            <Label text="Historique des Rendez-vous"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #202124;"/>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <VBox fx:id="rdvListContainer" spacing="0" style="-fx-padding: 0 0 10 0;"/>
        </ScrollPane>

    </VBox>

</VBox>
