<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.LoginController"
      style="-fx-background-color: white;" prefWidth="1200" prefHeight="700">

    <!-- Section Gauche : Illustration -->
    <VBox alignment="CENTER" style="-fx-background-color: #E3F2FD;" HBox.hgrow="ALWAYS" maxWidth="Infinity">
        <ImageView fx:id="brandingImageView" fitWidth="300" preserveRatio="true">
            <!-- Placeholder image or app logo -->
             <image>
                <Image url="@login_image.png"/>
            </image>
        </ImageView>
    </VBox>

    <!-- Section Droite : Formulaire -->
    <VBox spacing="20" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="400" style="-fx-padding: 40;">
        <Label text="Bienvenue" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
        <Label text="Connectez-vous à votre compte" style="-fx-font-size: 14px; -fx-text-fill: #757575;"/>

        <VBox spacing="15">
            <VBox spacing="5">
                <Label text="Email" style="-fx-font-weight: bold; -fx-text-fill: #424242;"/>
                <TextField fx:id="emailField" promptText="exemple@email.com" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #E0E0E0; -fx-border-radius: 5;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #424242;"/>
                <PasswordField fx:id="passwordField" promptText="........" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #E0E0E0; -fx-border-radius: 5;"/>
            </VBox>

            <Hyperlink text="Mot de passe oublié ?" style="-fx-text-fill: #1565C0; -fx-border-color: transparent;" onAction="#handleForgotPassword"
                       alignment="CENTER_RIGHT"/>

            <Button text="Se connecter" onAction="#handleLogin" maxWidth="Infinity"
                    style="-fx-background-color: #1976D2; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 5; -fx-cursor: hand;"/>

            <Button text="G  Continuer avec Google" onAction="#handleGoogleLogin" maxWidth="Infinity"
                    style="-fx-background-color: white; -fx-text-fill: #757575; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 5; -fx-border-color: #E0E0E0; -fx-border-radius: 5; -fx-cursor: hand;"/>

            <Button text="👤  Se connecter avec Face ID" onAction="#handleFaceLogin" maxWidth="Infinity"
                    style="-fx-background-color: #1B5E20; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 5; -fx-cursor: hand;"/>
        </VBox>

        <HBox alignment="CENTER" spacing="5">
            <Label text="Pas encore de compte ?" style="-fx-text-fill: #757575;"/>
            <Hyperlink text="Créer un compte" onAction="#handleGoToSignup" style="-fx-text-fill: #1565C0; -fx-font-weight: bold; -fx-border-color: transparent;"/>
        </HBox>
        
        <Label fx:id="messageLabel" textFill="RED"/>
    </VBox>

</HBox>
