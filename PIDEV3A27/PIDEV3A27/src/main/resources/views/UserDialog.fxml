<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.UserDialogController"
      style="-fx-padding: 20; -fx-background-color: white;">

    <Label text="Gestion Utilisateur" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <GridPane vgap="10" hgap="10">
        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

        <Label text="Nom:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nomField" promptText="Votre nom" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Prénom:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <TextField fx:id="prenomField" promptText="Votre prénom" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="emailField" promptText="exemple@email.com" GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.columnSpan="3"/>

        <Label text="Téléphone:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="telephoneField" promptText="+33 6..." GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Age:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
        <TextField fx:id="ageField" promptText="Age" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

        <Label text="Mot de passe:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <PasswordField fx:id="passwordField" promptText="........" GridPane.rowIndex="3" GridPane.columnIndex="1" GridPane.columnSpan="3"/>

        <Label text="Rôle:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <ComboBox fx:id="roleComboBox" promptText="Sélectionnez votre rôle" GridPane.rowIndex="4" GridPane.columnIndex="1" GridPane.columnSpan="3" maxWidth="Infinity"/>
    </GridPane>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Annuler" fx:id="cancelButton" onAction="#handleCancel"/>
        <Button text="Enregistrer" fx:id="saveButton" onAction="#handleSave" style="-fx-background-color: #7B1FA2; -fx-text-fill: white;"/>
    </HBox>

</VBox>
