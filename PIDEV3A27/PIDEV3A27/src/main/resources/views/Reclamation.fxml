<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.ReclamationController"
      spacing="20"
      style="-fx-background-color: white;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="✉️" style="-fx-font-size: 38px; -fx-text-fill: #2c3e50;"/>
        <VBox spacing="2">
            <Label text="Réclamation"
                   style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Nous sommes à votre écoute"
                   style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
    </HBox>

    <!-- Carte Formulaire -->
    <VBox spacing="20"
          style="-fx-background-color: white; 
                 -fx-padding: 30; 
                 -fx-background-radius: 20; 
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);">

        <!-- Objet -->
        <VBox spacing="10">
            <Label text="Objet" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2c3e50;"/>
            <TextField fx:id="objetField" promptText="Objet" 
                       style="-fx-background-color: white; -fx-border-color: #cbd5e0; -fx-border-radius: 8; -fx-padding: 10;"/>
        </VBox>

        <!-- Urgence -->
        <VBox spacing="10">
            <Label text="Urgence" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2c3e50;"/>
            <HBox spacing="20" alignment="CENTER_LEFT">
                <RadioButton fx:id="highRadio" text="High" style="-fx-font-size: 15px; -fx-text-fill: #2c3e50;"/>
                <RadioButton fx:id="mediumRadio" text="Medium" style="-fx-font-size: 15px; -fx-text-fill: #2c3e50;"/>
                <RadioButton fx:id="lowRadio" text="Low" style="-fx-font-size: 15px; -fx-text-fill: #2c3e50;"/>
            </HBox>
        </VBox>

        <!-- Description -->
        <VBox spacing="10">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Description" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2c3e50;"/>
                <Button fx:id="micButton" text="🎤 Dictée vocale" onAction="#handleMicrophone" 
                        style="-fx-background-color: #f1f2f6; -fx-text-fill: #2c3e50; -fx-background-radius: 5; -fx-cursor: hand;"/>
                <Label fx:id="micStatusLabel" text="" style="-fx-text-fill: red; -fx-font-size: 12px;"/>
            </HBox>
            <TextArea fx:id="descriptionArea" promptText="Décrivez votre réclamation en détail..." 
                      prefHeight="150" wrapText="true"
                      style="-fx-background-color: white; -fx-border-color: #cbd5e0; -fx-border-radius: 8; -fx-padding: 5;"/>
        </VBox>

        <!-- Boutons -->
        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
            <Button text="Annuler" onAction="#handleAnnuler"
                    style="-fx-background-color: #f1f2f6; -fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-padding: 12 30; -fx-background-radius: 10; -fx-cursor: hand;"/>
            <Button text="Envoyer" onAction="#handleEnvoyer"
                    style="-fx-background-color: #3182ce; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 40; -fx-background-radius: 10; -fx-cursor: hand;"/>
        </HBox>

    </VBox>

</VBox>
