<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.ReclamationController"
      spacing="20"
      style="-fx-background-color: white;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="📩" style="-fx-font-size: 32px;"/>
        <VBox spacing="5">
            <Label text="Réclamation"
                   style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
            <Label text="Nous sommes à votre écoute"
                   style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
        </VBox>
    </HBox>

    <Separator/>

    <!-- Carte Formulaire -->
    <VBox spacing="20"
          style="-fx-background-color: #F9F9F9;
                 -fx-padding: 25;
                 -fx-background-radius: 10;">

        <!-- Type -->
        <VBox spacing="8">
            <Label text="Type"
                   style="-fx-font-weight: bold; -fx-font-size: 14px;"/>

            <ComboBox fx:id="typeComboBox"
                      promptText="Type de réclamation"
                      prefWidth="400"/>
        </VBox>

        <!-- Description -->
        <VBox spacing="8">
            <Label text="Description"
                   style="-fx-font-weight: bold; -fx-font-size: 14px;"/>

            <TextArea fx:id="descriptionArea"
                      promptText="Décrivez votre réclamation en détail..."
                      prefHeight="180"
                      wrapText="true"/>
        </VBox>

        <!-- Boutons -->
        <HBox spacing="15" alignment="CENTER_RIGHT">
            <Button fx:id="annulerButton"
                    text="Annuler"
                    onAction="#handleAnnuler"
                    style="-fx-background-color: #E0E0E0;
                           -fx-text-fill: black;
                           -fx-padding: 10 25;
                           -fx-background-radius: 5;"/>

            <Button fx:id="envoyerButton"
                    text="Envoyer"
                    onAction="#handleEnvoyer"
                    style="-fx-background-color: #1976D2;
                           -fx-text-fill: white;
                           -fx-padding: 10 25;
                           -fx-background-radius: 5;"/>
        </HBox>

    </VBox>

    <Separator/>

    <!-- Liste des Réclamations -->
    <VBox spacing="10" VBox.vgrow="ALWAYS">
        <Label text="Mes Réclamations"
               style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

        <TableView fx:id="reclamationTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colType" text="Type"/>
                <TableColumn fx:id="colDate" text="Date"/>
                <TableColumn fx:id="colStatut" text="Statut"/>
                <TableColumn fx:id="colDescription" text="Description"/>
                <TableColumn fx:id="colAction" text="Action" prefWidth="120"/>
            </columns>

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

</VBox>
