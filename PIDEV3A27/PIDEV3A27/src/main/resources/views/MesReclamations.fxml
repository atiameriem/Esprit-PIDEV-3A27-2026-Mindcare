<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.MesReclamationsController"
      spacing="20"
      style="-fx-background-color: #f8f9fa;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="🗂️" style="-fx-font-size: 32px;"/>
        <VBox spacing="5">
            <Label text="Mes Réclamations"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Consultez et gérez vos demandes en cours"
                   style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
        <Pane HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Recherche -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Rechercher par objet ou description..." 
                   HBox.hgrow="ALWAYS" style="-fx-padding: 10; -fx-background-radius: 8; -fx-border-color: #cbd5e0; -fx-border-radius: 8; -fx-font-size: 14px;"/>
    </HBox>

    <Separator/>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <FlowPane fx:id="reclamationGrid" hgap="20" vgap="20" alignment="TOP_LEFT">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
        </FlowPane>
    </ScrollPane>

</VBox>
