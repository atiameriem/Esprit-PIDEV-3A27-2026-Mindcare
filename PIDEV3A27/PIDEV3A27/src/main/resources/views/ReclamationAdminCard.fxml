<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns:fx="http://javafx.com/fxml" 
      fx:controller="controllers.ReclamationAdminCardController"
      spacing="12" 
      style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 20; -fx-min-width: 350; -fx-max-width: 350;">

    <HBox spacing="10" alignment="CENTER_LEFT">
        <VBox HBox.hgrow="ALWAYS" spacing="2">
            <Label fx:id="userNameLabel" text="Chargement..." style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label fx:id="dateLabel" text="Date" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
        <Label fx:id="urgencyLabel" text="URGENCE" style="-fx-font-size: 10px; -fx-text-fill: white; -fx-padding: 3 8; -fx-background-radius: 10; -fx-background-color: #e74c3c; -fx-font-weight: bold;"/>
    </HBox>

    <Separator/>

    <VBox spacing="8">
        <HBox spacing="5" alignment="CENTER_LEFT">
            <Label text="Objet:" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <Label fx:id="objetLabel" text="Objet de la réclamation" wrapText="true" style="-fx-text-fill: #2c3e50;"/>
        </HBox>
        <VBox spacing="4">
            <Label text="Description:" style="-fx-font-weight: bold; -fx-text-fill: #34495e;"/>
            <Label fx:id="descriptionLabel" text="Description détaillée ici..." wrapText="true" minHeight="60" style="-fx-text-fill: #34495e; -fx-background-color: #f8f9fa; -fx-padding: 8; -fx-background-radius: 5;"/>
        </VBox>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Label fx:id="statutLabel" text="En attente" style="-fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="treatBtn" text="Traiter" onAction="#handleTreat"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 8 20;"/>
        <Label fx:id="doneLabel" text="✓ Terminé" visible="false" managed="false"
               style="-fx-text-fill: #27ae60; -fx-font-weight: bold; -fx-font-size: 14px;"/>
    </HBox>

</VBox>
