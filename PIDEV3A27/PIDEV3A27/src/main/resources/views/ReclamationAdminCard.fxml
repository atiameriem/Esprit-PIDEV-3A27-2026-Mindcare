<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Rectangle?>

<HBox xmlns:fx="http://javafx.com/fxml" 
      fx:controller="controllers.ReclamationAdminCardController"
      spacing="0" 
      style="-fx-background-color: white; 
             -fx-background-radius: 22; 
             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 20, 0, 0, 8); 
             -fx-border-color: #F1F5F9; 
             -fx-border-radius: 22; 
             -fx-border-width: 1.5;"
      prefWidth="420" maxWidth="420" minWidth="420">

    <!-- Priority Strip (Left) -->
    <Region fx:id="priorityStrip" prefWidth="6" minWidth="6" 
            style="-fx-background-color: #EF4444; -fx-background-radius: 22 0 0 22;"/>

    <VBox spacing="18" HBox.hgrow="ALWAYS" style="-fx-padding: 24;">
        
        <!-- Header Section -->
        <HBox spacing="14" alignment="CENTER_LEFT">
            <StackPane style="-fx-background-color: #EFF6FF; -fx-background-radius: 12; -fx-min-width: 48; -fx-min-height: 48;">
                <Label text="👤" style="-fx-font-size: 22px;"/>
            </StackPane>
            
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label fx:id="userNameLabel" text="Chargement..." 
                       style="-fx-font-size: 17px; -fx-font-weight: 800; -fx-text-fill: #1E293B;"/>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="📅" style="-fx-font-size: 11px; -fx-opacity: 0.6;"/>
                    <Label fx:id="dateLabel" text="Date" 
                           style="-fx-font-size: 12px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
            
            <Label fx:id="statutLabel" text="EN ATTENTE" 
                   style="-fx-font-size: 10px; -fx-font-weight: 900; -fx-text-fill: #B45309; 
                          -fx-background-color: #FEF3C7; -fx-padding: 6 14; -fx-background-radius: 10; 
                          -fx-letter-spacing: 0.5px;"/>
        </HBox>

        <!-- Category & Urgence Badges -->
        <HBox spacing="10">
            <HBox fx:id="categorieContainer" alignment="CENTER" spacing="6" visible="false" managed="false"
                  style="-fx-background-color: #F1F5F9; -fx-padding: 5 12; -fx-background-radius: 8;">
                <Label text="🏷️" style="-fx-font-size: 11px;"/>
                <Label fx:id="categorieLabel" text="CATÉGORIE" style="-fx-font-size: 10px; -fx-font-weight: 900; -fx-text-fill: #475569;"/>
            </HBox>
            
            <HBox fx:id="urgencyContainer" alignment="CENTER" spacing="6"
                  style="-fx-background-color: #FEE2E2; -fx-padding: 5 12; -fx-background-radius: 8;">
                <Label fx:id="urgencyIcon" text="⚡" style="-fx-font-size: 11px;"/>
                <Label fx:id="urgencyLabel" text="URGENCE" style="-fx-font-size: 10px; -fx-font-weight: 900; -fx-text-fill: #EF4444;"/>
            </HBox>
        </HBox>

        <Separator prefWidth="200" style="-fx-opacity: 0.3;"/>

        <!-- Content Area -->
        <VBox spacing="14">
            <VBox spacing="6">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="📌" style="-fx-font-size: 12px; -fx-opacity: 0.7;"/>
                    <Label text="OBJET" style="-fx-font-weight: 900; -fx-font-size: 11px; -fx-text-fill: #64748B; -fx-letter-spacing: 1px;"/>
                </HBox>
                <Label fx:id="objetLabel" text="Objet de la réclamation" wrapText="true" 
                       style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #1E293B;"/>
            </VBox>
            
            <VBox spacing="6">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="📝" style="-fx-font-size: 12px; -fx-opacity: 0.7;"/>
                    <Label text="DESCRIPTION" style="-fx-font-weight: 900; -fx-font-size: 11px; -fx-text-fill: #64748B; -fx-letter-spacing: 1px;"/>
                </HBox>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" 
                            maxHeight="130" minHeight="60"
                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0; -fx-border-color: transparent;">
                    <Label fx:id="descriptionLabel" text="Description détaillée ici..." wrapText="true" 
                           style="-fx-font-size: 14px; -fx-text-fill: #334155; -fx-line-spacing: 1.4;"/>
                </ScrollPane>
            </VBox>

            <!-- AI Summary (If available) -->
            <VBox fx:id="resumeContainer" spacing="8" 
                  style="-fx-background-color: #FAF5FF; -fx-padding: 16; -fx-background-radius: 16; -fx-border-color: #E9D5FF; -fx-border-width: 1;" 
                  visible="false" managed="false">
                 <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="✨" style="-fx-font-size: 14px;"/>
                    <Label text="RÉSUMÉ IA" style="-fx-font-weight: 900; -fx-font-size: 11px; -fx-text-fill: #7E22CE; -fx-letter-spacing: 1px;"/>
                 </HBox>
                 <Label fx:id="resumeLabel" text="Résumé..." wrapText="true" 
                        style="-fx-font-size: 14px; -fx-text-fill: #581C87; -fx-font-weight: 700; -fx-line-spacing: 1.2;"/>
            </VBox>

            <!-- Admin Response (If treated) -->
            <VBox fx:id="reponseContainerAdmin" spacing="8" 
                  style="-fx-background-color: #F0FDF4; -fx-padding: 16; -fx-background-radius: 16; -fx-border-color: #DCFCE7; -fx-border-width: 1;" 
                  visible="false" managed="false">
                 <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="✉" style="-fx-font-size: 14px;"/>
                    <Label text="RÉPONSE ENVOYÉE" style="-fx-font-weight: 900; -fx-font-size: 11px; -fx-text-fill: #15803D; -fx-letter-spacing: 1px;"/>
                 </HBox>
                 <Label fx:id="reponseLabelAdmin" text="Réponse..." wrapText="true" 
                        style="-fx-font-size: 14px; -fx-text-fill: #166534; -fx-font-style: italic; -fx-line-spacing: 1.2;"/>
            </VBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS" minHeight="5"/>

        <!-- Footer: Actions -->
        <HBox alignment="CENTER_RIGHT" spacing="12">
            <Label fx:id="doneLabel" text="✓ Traité avec succès" visible="false" managed="false"
                   style="-fx-text-fill: #16A34A; -fx-font-weight: 800; -fx-font-size: 14px; -fx-padding: 10 0;"/>
            
            <Button fx:id="repondreBtn" text="🚀 Répondre" onAction="#handleRepondre"
                    style="-fx-background-color: linear-gradient(to right, #2563EB, #3B82F6); 
                           -fx-text-fill: white; -fx-font-weight: 900; -fx-background-radius: 12; 
                           -fx-cursor: hand; -fx-padding: 12 30; 
                           -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.3), 12, 0, 0, 4);"/>
        </HBox>
    </VBox>
</HBox>

