<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.ForgotPasswordController"
      style="-fx-background-color: white;" prefWidth="1200" prefHeight="700">

    <!-- Section Gauche : Illustration -->
    <VBox alignment="CENTER" style="-fx-background-color: #E3F2FD;" HBox.hgrow="ALWAYS" maxWidth="Infinity">
        <ImageView fitWidth="300" preserveRatio="true">
             <image>
                <Image url="@login_image.png"/>
            </image>
        </ImageView>
    </VBox>

    <!-- Section Droite : Formulaire -->
    <VBox spacing="20" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="400" style="-fx-padding: 40;">
        <Label text="Mot de passe oublié ?" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
        
        <!-- Step 1: Email Entry -->
        <VBox fx:id="emailStepBox" spacing="20">
            <Label text="Entrez votre email pour recevoir un code de réinitialisation." wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #757575;"/>
            <VBox spacing="5">
                <Label text="Email" style="-fx-font-weight: bold; -fx-text-fill: #424242;"/>
                <TextField fx:id="forgotEmailField" promptText="exemple@email.com" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #E0E0E0;"/>
            </VBox>
            <Button text="Envoyer le code" onAction="#handleSendResetCode" maxWidth="Infinity"
                    style="-fx-background-color: #1976D2; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 5; -fx-cursor: hand;"/>
        </VBox>

        <!-- Step 2: Code & New Password entry (Initially hidden) -->
        <VBox fx:id="resetStepBox" spacing="20" visible="false" managed="false">
            <Label text="Entrez le code reçu et votre nouveau mot de passe." wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #757575;"/>
            
            <VBox spacing="5">
                <Label text="Code de vérification" style="-fx-font-weight: bold; -fx-text-fill: #424242;"/>
                <TextField fx:id="verificationCodeField" promptText="123456" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #E0E0E0;"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Nouveau mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #424242;"/>
                <PasswordField fx:id="newPasswordField" promptText="........" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #E0E0E0;"/>
            </VBox>

            <Button text="Réinitialiser le mot de passe" onAction="#handleResetPassword" maxWidth="Infinity"
                    style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 5; -fx-cursor: hand;"/>
            
            <HBox alignment="CENTER" spacing="5">
                <Label text="Vous n'avez pas reçu de code ?" style="-fx-text-fill: #757575;"/>
                <Hyperlink text="Renvoyer le code" onAction="#handleResendCode" style="-fx-text-fill: #1976D2; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>

        <HBox alignment="CENTER" spacing="5">
            <Hyperlink text="Retour à la connexion" onAction="#handleBackToLogin" style="-fx-text-fill: #757575; -fx-border-color: transparent;"/>
        </HBox>
        
        <Label fx:id="forgotMessageLabel" textFill="#2E7D32" wrapText="true"/>
    </VBox>

</HBox>
