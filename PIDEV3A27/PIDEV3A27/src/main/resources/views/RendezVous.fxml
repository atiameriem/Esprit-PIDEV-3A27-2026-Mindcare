<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.RendezVousController"
      spacing="20"
      style="-fx-background-color: white;">
    <padding>
        <javafx.geometry.Insets top="30" right="30" bottom="30" left="30"/>
    </padding>


    <!-- Bouton visible (test) -->
    <HBox alignment="CENTER_RIGHT">
        <Button text="Bouton" />
    </HBox>


    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="📅" style="-fx-font-size: 32px;"/>
        <VBox spacing="5">
            <Label text="Gestion des Rendez-vous" 
                   style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
            <Label text="Consultez et gérez vos rendez-vous" 
                   style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
        </VBox>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button fx:id="addButton" text="➕ Nouveau rendez-vous" 
                style="-fx-background-color: #1976D2; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 5;"/>
    </HBox>

    <Separator/>

    <!-- Filtres et recherche -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <Label text="Rechercher:" style="-fx-font-weight: bold;"/>
        <TextField fx:id="searchField" promptText="Chercher un rendez-vous..." 
                   prefWidth="300" style="-fx-padding: 8 8 8 8;"/>
        
        <Label text="Filtrer:" style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="filterCombo" prefWidth="150" promptText="Tous">
            <items>
                <javafx.collections.FXCollections fx:factory="observableArrayList">
                    <java.lang.String fx:value="Tous"/>
                    <java.lang.String fx:value="À venir"/>
                    <java.lang.String fx:value="Passés"/>
                    <java.lang.String fx:value="Annulés"/>
                </javafx.collections.FXCollections>
            </items>
        </ComboBox>
    </HBox>

    <!-- Table des rendez-vous -->
    <TableView fx:id="rendezVousTable" VBox.vgrow="ALWAYS" 
               style="-fx-background-color: white;">
        <columns>
            <TableColumn text="Date" prefWidth="120"/>
            <TableColumn text="Heure" prefWidth="100"/>
            <TableColumn text="Patient" prefWidth="200"/>
            <TableColumn text="Type" prefWidth="150"/>
            <TableColumn text="Statut" prefWidth="120"/>
            <TableColumn text="Actions" prefWidth="150"/>
        </columns>
        <placeholder>
            <VBox spacing="10" alignment="CENTER">
                <padding>
                    <javafx.geometry.Insets top="30" right="30" bottom="30" left="30"/>
                </padding>

                <Label text="📅" style="-fx-font-size: 48px;"/>
                <Label text="Aucun rendez-vous pour le moment" 
                       style="-fx-font-size: 16px; -fx-text-fill: #999;"/>
                <Button text="Créer votre premier rendez-vous" 
                        style="-fx-background-color: #1976D2; -fx-text-fill: white; -fx-padding: 10 20;"/>
            </VBox>
        </placeholder>
    </TableView>

    <!-- Statistiques -->
    <HBox spacing="20">
        <VBox spacing="5" style="-fx-background-color: #E3F2FD; -fx-padding: 15 15 15 15; -fx-background-radius: 5;">
            <Label text="Total rendez-vous" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
            <Label fx:id="totalLabel" text="24" 
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1976D2;"/>
        </VBox>
        
        <VBox spacing="5" style="-fx-background-color: #E8F5E9; -fx-padding: 15 15 15 15; -fx-background-radius: 5;">
            <Label text="À venir" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
            <Label fx:id="upcomingLabel" text="5" 
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #388E3C;"/>
        </VBox>
        
        <VBox spacing="5" style="-fx-background-color: #FFF3E0; -fx-padding: 15 15 15 15; -fx-background-radius: 5;">
            <Label text="Ce mois" style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
            <Label fx:id="monthLabel" text="12" 
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #F57C00;"/>
        </VBox>
    </HBox>

</VBox>
