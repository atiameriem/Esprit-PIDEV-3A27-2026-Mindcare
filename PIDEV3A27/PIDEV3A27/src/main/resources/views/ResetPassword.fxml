<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml" fx:controller="controllers.LoginController"
      style="-fx-background-color: white;" prefWidth="1200" prefHeight="700">

    <!-- Section Gauche : Illustration -->
    <VBox alignment="CENTER" style="-fx-background-color: #E3F2FD;" HBox.hgrow="ALWAYS" maxWidth="Infinity">
        <ImageView fitWidth="300" preserveRatio="true">
             <image>
                <Image url="@login_image.png"/>
            </image>
        </ImageView>
    </VBox>

    <!-- Section Droite : Formulaire -->
    <VBox spacing="20" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="400" style="-fx-padding: 40;">
        <Label text="Réinitialisation" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1565C0;"/>
        <Label text="Créez un nouveau mot de passe." style="-fx-font-size: 14px; -fx-text-fill: #757575;"/>

        <VBox spacing="5">
            <Label text="Nouveau mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #424242;"/>
            <PasswordField fx:id="resetPasswordField" promptText="........" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #E0E0E0;"/>
        </VBox>

        <VBox spacing="5">
            <Label text="Confirmer le mot de passe" style="-fx-font-weight: bold; -fx-text-fill: #424242;"/>
            <PasswordField fx:id="resetConfirmPasswordField" promptText="........" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #E0E0E0;"/>
        </VBox>

        <Button text="Confirmer" onAction="#handleChangePasswordSubmit" maxWidth="Infinity"
                style="-fx-background-color: #1976D2; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 5; -fx-cursor: hand;"/>
        
        <Label fx:id="resetMessageLabel" textFill="RED"/>
    </VBox>

</HBox>
