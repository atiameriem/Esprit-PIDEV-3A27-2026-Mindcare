<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.fxml.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ForumController"
            stylesheets="@../css/forum.css"
            styleClass="root">

    <!-- TOP -->
    <top>
        <VBox spacing="10" styleClass="topArea">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="searchField"
                           promptText="Rechercher..."
                           HBox.hgrow="ALWAYS"
                           styleClass="searchField"/>

                <ComboBox fx:id="sortCombo"
                          promptText="Trier par"
                          prefWidth="160"
                          styleClass="combo"/>

                <StackPane>
                    <Button fx:id="notifButton" text="🔔" onAction="#onNotifClick" styleClass="notifBtn"/>
                    <!-- mouseTransparent pour éviter de bloquer le clic sur le bouton -->
                    <Label fx:id="notifBadge" text="0" visible="false" managed="false" mouseTransparent="true" styleClass="notifBadge"/>
                </StackPane>

                <Button fx:id="addPostButton"
                        text="+ Ajouter un Post"
                        styleClass="primaryBtn"/>
            </HBox>

            <!-- Tabs -->
            <HBox spacing="16" alignment="CENTER_LEFT" styleClass="tabsBar">
                <fx:define>
                    <ToggleGroup fx:id="tabsGroup"/>
                </fx:define>

                <ToggleButton fx:id="tabAllPosts"
                              text="Tous les posts"
                              toggleGroup="$tabsGroup"
                              selected="true"
                              styleClass="tabBtn"/>

                <ToggleButton fx:id="tabMyPosts"
                              text="Mes posts"
                              toggleGroup="$tabsGroup"
                              styleClass="tabBtn"/>

                <!-- Visible uniquement pour admin (géré dans le controller) -->
                <ToggleButton fx:id="tabReports"
                              text="Signalements"
                              toggleGroup="$tabsGroup"
                              styleClass="tabBtn"/>

                <ToggleButton fx:id="tabDashboard"
                              text="Dashboard"
                              toggleGroup="$tabsGroup"
                              styleClass="tabBtn"/>
            </HBox>

            <Separator/>
        </VBox>
    </top>

    <!-- CENTER -->
    <center>
        <!-- Two-column layout: posts on the left, recommended/profile on the right.
             The controller will:
              - fill the right column with Recommended (All posts) or Profile (My posts)
              - hide the right column for admin tabs (Reports / Dashboard)
         -->
        <HBox spacing="18" styleClass="contentArea">

            <!-- LEFT: scrollable posts list (full width) -->
            <ScrollPane fx:id="scrollPosts" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="scroll" HBox.hgrow="ALWAYS">
                <VBox fx:id="postsContainer" spacing="12" styleClass="leftColumn"/>
            </ScrollPane>

            <!-- RIGHT: recommended/profile (hidden on admin tabs) -->
            <VBox fx:id="recommendedContainer" spacing="12" styleClass="rightColumn" prefWidth="320" minWidth="260"/>
        </HBox>
    </center>

</BorderPane>
