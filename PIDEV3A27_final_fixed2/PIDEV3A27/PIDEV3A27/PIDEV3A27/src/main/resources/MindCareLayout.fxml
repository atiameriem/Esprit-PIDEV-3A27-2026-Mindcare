<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.MindCareLayoutController"
            stylesheets="@mindcare.css"
            styleClass="root">

    <!-- SIDEBAR -->
    <left>
        <VBox spacing="14" styleClass="sidebar" BorderPane.alignment="TOP_LEFT">

            <!-- Brand -->
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="brandBox">
                <StackPane prefWidth="34" prefHeight="34" styleClass="logoBubbleDark">
                    <Label text="🧠" styleClass="logoIconDark"/>
                </StackPane>
                <Label text="MindCare" styleClass="brandTitle"/>
            </HBox>

            <!-- Profile card -->
            <VBox spacing="6" styleClass="profileCard">
                <Label text="Bonjour," styleClass="mutedWhite"/>
                <Label fx:id="profileNameLabel" text="" styleClass="whiteBold"/>
                <Label fx:id="profileRoleLabel" text="" styleClass="mutedWhite"/>
            </VBox>

            <!-- Menu -->
            <VBox spacing="10" styleClass="menuBox">
                <!-- Accueil button with home icon -->
                <Button text="🏠  Accueil" styleClass="sideBtn" onAction="#loadAccueil"/>

                <!-- Consultation dropdown -->
                <TitledPane text="📋  Consultation" expanded="true" styleClass="sidePane">
                    <content>
                        <VBox spacing="8" styleClass="submenu">
                            <Button text="📅  Rendez-vous" styleClass="subBtn" onAction="#loadRendezVous"/>

                            <!-- ✅ Visible uniquement pour le psychologue -->
                            <Button fx:id="statsButton"
                                    text="📊  Statistiques"
                                    styleClass="subBtn"
                                    onAction="#loadRendezVousStats"
                                    visible="true" managed="true"/>

                            <!-- ✅ Demande prof : supprimer le bouton Compte-rendu du sidebar.
                                 Le compte-rendu est maintenant accessible depuis l'interface Rendez-vous (bouton "Consultations terminées"). -->
                        </VBox>
                    </content>
                </TitledPane>

                <!-- Forum dropdown - ACTIVE/EXPANDED -->
                <TitledPane text="💬  Forum" expanded="false" styleClass="sidePane">
                    <content>
                        <VBox spacing="8" styleClass="submenu">
                            <Button text="📰  Fil d'actualité" styleClass="subBtn" onAction="#loadForum"/>
                            <Button text="🤖  Chatbot" styleClass="subBtn" onAction="#loadChatbot"/>
                        </VBox>
                    </content>
                </TitledPane>

                <!-- Test psychologique dropdown -->
                <TitledPane text="📊  Test psychologique" expanded="false" styleClass="sidePane">
                    <content>
                        <VBox spacing="8" styleClass="submenu">
                            <Button text="✍️  Passer tests" styleClass="subBtn" onAction="#loadPasserTests"/>
                            <Button text="📈  Suivie" styleClass="subBtn" onAction="#loadSuivie"/>
                        </VBox>
                    </content>
                </TitledPane>

                <!-- Compte et réclamation dropdown -->
                <TitledPane text="👤  Compte et réclamation" expanded="false" styleClass="sidePane">
                    <content>
                        <VBox spacing="8" styleClass="submenu">
                            <Button text="👁️  Consulter profil" styleClass="subBtn" onAction="#loadProfil"/>
                            <Button text="⚠️  Réclamation" styleClass="subBtn" onAction="#loadReclamation"/>
                        </VBox>
                    </content>
                </TitledPane>

                <!-- Formation dropdown -->
                <TitledPane text="🎓  Formation" expanded="false" styleClass="sidePane">
                    <content>
                        <VBox spacing="8" styleClass="submenu">
                            <Button text="📚  Réserver formation" styleClass="subBtn" onAction="#loadReserverFormation"/>
                            <Button text="📖  Consulter support" styleClass="subBtn" onAction="#loadConsulterSupport"/>
                        </VBox>
                    </content>
                </TitledPane>

                <!-- Locaux button with location icon -->
                <Button text="📍  Locaux" styleClass="sideBtn" onAction="#loadLocaux"/>
            </VBox>

            <!-- Spacer to push footer to bottom -->
            <Pane VBox.vgrow="ALWAYS"/>

            <!-- Footer copyright -->
            <Label text="© 2026 MindCare" styleClass="sidebarFooter"/>

        </VBox>
    </left>

    <!-- CENTER CONTENT -->
    <center>
        <StackPane styleClass="contentWrap">
            <VBox spacing="18" styleClass="contentInner">

                <!-- Header with title and logout button -->
                <HBox alignment="CENTER_LEFT" spacing="14" styleClass="contentHeader">
                    <!-- Left: brand title with icon -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <StackPane prefWidth="36" prefHeight="36" styleClass="logoBubble">
                            <Label text="🧠" styleClass="logoIcon"/>
                        </StackPane>

                        <VBox spacing="2">
                            <Label text="MindCare" styleClass="contentTopTitle"/>
                            <Label text="Psycho Forum" styleClass="contentTopSubtitle"/>
                        </VBox>
                    </HBox>

                    <!-- Spacer -->
                    <Pane HBox.hgrow="ALWAYS"/>

                    <!-- Right: Déconnexion button -->
                    <Button text="🚪  Déconnexion" styleClass="logoutBtn" onAction="#handleLogout"/>
                </HBox>

                <!-- Main content area - large white/light panel -->
                <!--
                    IMPORTANT:
                    Certains contrôleurs (ex: RendezVousController) utilisent scene.lookup("#contentArea")
                    pour naviguer vers d'autres vues. lookup() cherche via Node.id (CSS id) et pas fx:id.
                    Donc on définit aussi id="contentArea".
                -->
                <VBox fx:id="contentArea" id="contentArea" spacing="14" styleClass="mainContentPanel" VBox.vgrow="ALWAYS">
                    <!-- Empty content area - will be filled dynamically -->
                    <Label text="" style="-fx-min-height: 400px;"/>
                </VBox>

            </VBox>

            <!-- Help button in bottom right corner -->
            <Button text="?" styleClass="helpBtn" StackPane.alignment="BOTTOM_RIGHT"/>
        </StackPane>
    </center>

</BorderPane>
