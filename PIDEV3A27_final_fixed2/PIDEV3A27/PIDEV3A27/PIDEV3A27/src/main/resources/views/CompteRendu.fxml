<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.CompteRenduController"
      spacing="20"
      style="-fx-background-color: white;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="5">
            <Label text="Comptes-rendus de Séance"
                   style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
            <Label text="Suivez la progression thérapeutique de chaque séance"
                   style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
        </VBox>

        <Pane HBox.hgrow="ALWAYS"/>

        <Button fx:id="newCompteRenduButton"
                text="+ Nouveau Compte-rendu"
                onAction="#handleNewCompteRendu"
                style="-fx-background-color: #1a6b7c; -fx-text-fill: white;
                       -fx-padding: 10 20; -fx-background-radius: 5;"/>
    </HBox>

    <Separator/>

    <!-- SEARCH فقط -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="searchField"
                   promptText="Rechercher ici "
                   prefWidth="520"
                   style="-fx-padding: 10 10 10 10;"/>
    </HBox>

    <!-- LISTE -->
    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                style="-fx-background-color: white; -fx-background: white;">
        <VBox fx:id="compteRenduContainer" spacing="15"
              style="-fx-background-color: white; -fx-padding: 5 0 5 0;">
            <!-- ✅ les cartes seront ajoutées en Java -->
        </VBox>
    </ScrollPane>

</VBox>
