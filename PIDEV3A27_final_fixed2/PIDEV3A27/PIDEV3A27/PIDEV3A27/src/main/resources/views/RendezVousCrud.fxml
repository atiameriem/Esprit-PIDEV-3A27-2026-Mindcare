<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.RendezVousCrudController"
      spacing="20"
      style="-fx-background-color: white;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <!-- Header identique au style "Compte-rendu" -->
        <VBox spacing="5">

            <Label text="Mes Rendez-vous"
                   style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
            <!-- ✅ Sous-titre : même style que "Compte-rendu" -->
            <Label text="Planifiez et suivez vos rendez-vous en toute simplicité"
                   style="-fx-font-size: 14px; -fx-text-fill: #666;"/>
        </VBox>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="+ Nouveau Rendez-vous" onAction="#handleNewRendezVous"
                style="-fx-background-color: #1a6b7c; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 8;"/>
    </HBox>

    <Separator/>

    <!-- Search -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <!-- ✅ Demandé : pas de texte par défaut, seulement un prompt simple -->
        <TextField fx:id="searchField" promptText="Rechercher ici" prefWidth="520"
                   style="-fx-padding: 10 10 10 10;"/>
        <ComboBox fx:id="sortCombo"
                  prefWidth="200"
                  promptText="Trier par date"
                  style="-fx-padding: 8 10 8 10;">
        </ComboBox>

        <!-- ✅ Patient : accès à la lecture des comptes-rendus (lecture seule) -->
        <Button fx:id="patientCompteRenduButton"
                text="📄  Mes comptes-rendus"
                onAction="#openCompteRenduRead"
                visible="false" managed="false"
                style="-fx-background-color: #0f766e; -fx-text-fill: white; -fx-padding: 10 14; -fx-background-radius: 8;"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <ComboBox fx:id="pageSizeCombo" prefWidth="90"/>
        <Button fx:id="btnPrev" text="◀ Précédent" onAction="#prevPage"/>
        <Label fx:id="pageLabel" text="Page 1/1"/>
        <Button fx:id="btnNext" text="Suivant ▶" onAction="#nextPage"/>
    </HBox>
    <!-- List -->
    <!-- ✅ Demandé : pas de scroll horizontal -->
    <ScrollPane fx:id="listScroll" VBox.vgrow="ALWAYS" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: white; -fx-background: white;">
        <TilePane fx:id="rendezVousContainer"
                  prefColumns="2" hgap="18" vgap="18"
                  tileAlignment="TOP_LEFT"
                  style="-fx-background-color: white; -fx-padding: 5 0 5 0;">
            <!-- Cards générées en Java -->
        </TilePane>
    </ScrollPane>

</VBox>
