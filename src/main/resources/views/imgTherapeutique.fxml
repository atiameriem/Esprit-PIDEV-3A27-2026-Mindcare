<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.SuivieQuizController"
      styleClass="card"
      spacing="14"
      maxWidth="380"
      style="-fx-background-color:white;
             -fx-background-radius:20;
             -fx-padding:18;
             -fx-effect:dropshadow(gaussian,rgba(124,58,237,0.10),14,0,0,3);">

    <!-- ── En-tête ─────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="8">

        <Label text="🖼️"
               style="-fx-font-size:20px;"/>

        <Label text="Image thérapeutique"
               style="-fx-font-size:14px;
                      -fx-font-weight:800;
                      -fx-text-fill:#1F2937;"/>

        <!-- Spacer -->
        <Region HBox.hgrow="ALWAYS"/>

        <!-- Badge thème : EPANOUISSEMENT / EQUILIBRE / etc.
             Couleur injectée dynamiquement depuis Java        -->
        <Label fx:id="lblImageTheme"
               styleClass="image-theme-badge"
               style="-fx-font-size:10px;
                      -fx-font-weight:700;
                      -fx-background-radius:20;
                      -fx-padding:3 10 3 10;
                      -fx-text-fill:#7C3AED;
                      -fx-background-color:rgba(124,58,237,0.10);"/>

    </HBox>

    <Separator opacity="0.3"/>

    <!-- ── Zone image + overlay chargement ────────────────── -->
    <StackPane>

        <!-- Image 1024×768 → affichée en 340×200 -->
        <ImageView fx:id="imgTherapeutique"
                   fitWidth="340"
                   fitHeight="200"
                   preserveRatio="true"
                   smooth="true"
                   style="-fx-effect:dropshadow(gaussian,rgba(124,58,237,0.18),10,0,0,3);"/>

        <!-- Overlay spinner — visible=false par défaut,
             passé à true le temps de l'appel Pollinations AI -->
        <StackPane fx:id="paneImageLoading"
                   visible="false"
                   style="-fx-background-color:rgba(240,249,255,0.93);
                          -fx-background-radius:14;
                          -fx-border-color:rgba(167,139,250,0.25);
                          -fx-border-radius:14;
                          -fx-border-width:1.5;">
            <VBox alignment="CENTER" spacing="10">
                <padding><Insets top="40" bottom="40" left="20" right="20"/></padding>
                <Label text="🌸"
                       style="-fx-font-size:34px;"/>
                <Label text="IA en cours de génération..."
                       style="-fx-text-fill:#7C3AED;
                              -fx-font-size:12px;
                              -fx-font-weight:700;"/>
                <Label text="Pollinations AI · Gratuit · Sans clé"
                       style="-fx-text-fill:#94a3b8;
                              -fx-font-size:10px;
                              -fx-font-style:italic;"/>
            </VBox>
        </StackPane>

    </StackPane>

    <!-- ── Message thérapeutique ──────────────────────────── -->
    <Label fx:id="lblImageMessage"
           wrapText="true"
           maxWidth="340"
           style="-fx-font-size:12px;
                  -fx-text-fill:#475569;
                  -fx-font-style:italic;
                  -fx-line-spacing:3;
                  -fx-padding:2 0 0 0;"/>

    <!-- ── Bouton Nouvelle image ──────────────────────────── -->
    <Button fx:id="btnRegeneImage"
            text="✨ Nouvelle image"
            onAction="#regenererImage"
            maxWidth="Infinity"
            style="-fx-background-color:rgba(124,58,237,0.10);
                   -fx-text-fill:#7C3AED;
                   -fx-font-size:12px;
                   -fx-font-weight:800;
                   -fx-padding:10 18 10 18;
                   -fx-background-radius:12;
                   -fx-border-color:rgba(124,58,237,0.22);
                   -fx-border-radius:12;
                   -fx-border-width:1.5;
                   -fx-cursor:hand;"/>

</VBox>
