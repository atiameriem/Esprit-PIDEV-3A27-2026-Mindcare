<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="controllers.ResultatQuizController"
            fitToWidth="true"
            style="-fx-background:#F0F9FF;
                   -fx-background-color:#F0F9FF;
                   -fx-border-color:transparent;">

    <VBox spacing="16" alignment="TOP_CENTER">
        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

        <!-- ═══════ HEADER RÉSULTAT ══════════════════════════════ -->
        <VBox alignment="CENTER" spacing="14"
              style="-fx-background-color:linear-gradient(to bottom,#2c4a6e,#3d6a9e);
                     -fx-background-radius:24; -fx-padding:32;">

            <!-- Avatar emoji -->
            <StackPane prefWidth="90" prefHeight="90">
                <Circle radius="45"
                        fill="#ffffff22"/>
                <Label fx:id="lblEmoji" text="💪"
                       style="-fx-font-size:40px;"/>
            </StackPane>

            <!-- Titre quiz -->
            <Label fx:id="lblTitreQuiz" text="Test de stress"
                   style="-fx-font-size:14px; -fx-font-weight:700;
                          -fx-text-fill:white;
                          -fx-background-color:rgba(255,255,255,0.2);
                          -fx-background-radius:20;
                          -fx-padding:6 16 6 16;"/>

            <!-- Pourcentage animé -->
            <Label fx:id="lblPourcentage" text="0%"
                   style="-fx-font-size:64px; -fx-font-weight:900;
                          -fx-text-fill:white;"/>

            <!-- Message motivation -->
            <Label fx:id="lblMessage" text="N'abandonne pas !"
                   style="-fx-font-size:15px; -fx-font-weight:700;
                          -fx-text-fill:rgba(255,255,255,0.9);"/>

            <!-- Barre progression -->
            <ProgressBar fx:id="progressBar" progress="0"
                         prefWidth="320" prefHeight="10"
                         style="-fx-accent:#10B981;
                                -fx-background-color:rgba(255,255,255,0.2);
                                -fx-background-radius:10;"/>
        </VBox>

        <!-- ═══════ STATS ════════════════════════════════════════ -->
        <HBox spacing="16" alignment="CENTER">

            <!-- Score brut -->
            <VBox alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS"
                  style="-fx-background-color:white;
                         -fx-background-radius:20;
                         -fx-padding:20;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),10,0,0,2);">
                <StackPane prefWidth="48" prefHeight="48">
                    <Circle radius="24"
                            fill="rgba(167,139,250,0.15)"/>
                    <Label text="🎯" style="-fx-font-size:20px;"/>
                </StackPane>
                <Label text="Score obtenu"
                       style="-fx-font-size:11px; -fx-text-fill:#9CA3AF;
                              -fx-font-weight:700;"/>
                <Label fx:id="lblScore" text="0 pts"
                       style="-fx-font-size:22px; -fx-font-weight:900;
                              -fx-text-fill:#7C3AED;"/>
            </VBox>

            <!-- Niveau -->
            <VBox alignment="CENTER" spacing="8" HBox.hgrow="ALWAYS"
                  style="-fx-background-color:white;
                         -fx-background-radius:20;
                         -fx-padding:20;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),10,0,0,2);">
                <StackPane prefWidth="48" prefHeight="48">
                    <Circle radius="24"
                            fill="rgba(255,107,157,0.15)"/>
                    <Label text="📊" style="-fx-font-size:20px;"/>
                </StackPane>
                <Label text="Niveau"
                       style="-fx-font-size:11px; -fx-text-fill:#9CA3AF;
                              -fx-font-weight:700;"/>
                <Label fx:id="lblNiveau" text="moyen"
                       style="-fx-font-size:22px; -fx-font-weight:900;
                              -fx-text-fill:#F59E0B;"/>
            </VBox>
        </HBox>

        <!-- ═══════ CONSEIL IA ════════════════════════════════════ -->
        <VBox spacing="10"
              style="-fx-background-color:white;
                     -fx-background-radius:20;
                     -fx-padding:20;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),10,0,0,2);">
            <Label text="💡 Conseil personnalisé"
                   style="-fx-font-size:14px; -fx-font-weight:800;
                          -fx-text-fill:#1F2937;"/>
            <Label fx:id="lblConseil"
                   text="Génération en cours..."
                   wrapText="true"
                   style="-fx-font-size:13px; -fx-text-fill:#374151;
                          -fx-line-spacing:4;"/>
        </VBox>

        <!-- ═══════ BOUTON RETOUR ══════════════════════════════════ -->
        <Button text="🔄 Faire un autre test"
                onAction="#retourQuiz"
                maxWidth="Infinity"
                style="-fx-background-color:#7C3AED;
                       -fx-text-fill:white;
                       -fx-font-size:14px; -fx-font-weight:800;
                       -fx-padding:14 0; -fx-background-radius:16;
                       -fx-cursor:hand;"/>

    </VBox>
</ScrollPane>