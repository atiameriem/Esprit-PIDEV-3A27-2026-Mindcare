<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.FormationController"
      spacing="20"
      style="-fx-background-color: white;">

    <padding>
        <Insets top="20" right="30" bottom="20" left="30"/>
    </padding>

    <!-- ===== HEADER ===== -->
    <HBox alignment="CENTER_LEFT" spacing="15" 
          style="-fx-padding: 0 0 10 0;">
        <Label text="🎓" style="-fx-font-size: 32px;"/>
        <VBox spacing="5">
            <Label text="Formations en psychologie"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1F2A33;"/>
            <Label text="Votre espace d'apprentissage continu"
                   style="-fx-font-size: 14px; -fx-text-fill: #5F7F8B;"/>
        </VBox>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="➕ Ajouter une formation"
                onAction="#openAjouterFormation"
                style="-fx-background-color: linear-gradient(to right, #5C98A8, #7FB9C7); 
                       -fx-text-fill: white; 
                       -fx-padding: 10 25; 
                       -fx-background-radius: 14; 
                       -fx-font-weight: bold;
                       -fx-cursor: hand;"/>
    </HBox>

    <!-- ===== NAVIGATION TABS ===== -->
    <HBox spacing="10" style="-fx-padding: 0;">
        <Button fx:id="allFormationsBtn" text="Toutes les formations" 
                onAction="#showAllFormations"
                style="-fx-background-color: #5C98A8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20;"/>
        <Button fx:id="myFormationsBtn" text="Mes formations" 
                onAction="#showMyFormations"
                style="-fx-background-color: white; -fx-text-fill: #1F2A33; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20; -fx-border-color: #DDD; -fx-border-radius: 20;"/>
    </HBox>

    <!-- ===== BARRE DE RECHERCHE & FILTRES ===== -->
    <HBox fx:id="filterBar" spacing="15" alignment="CENTER_LEFT" 
          style="-fx-padding: 10 0;">
        <TextField fx:id="searchField"
                   promptText="Rechercher une formation..."
                   prefWidth="350"
                   style="-fx-background-radius: 14; -fx-padding: 10;"/>

        <ComboBox fx:id="sortCombo" prefWidth="150" promptText="Trier par" style="-fx-background-radius: 14;"/>
        <ComboBox fx:id="categoryCombo" prefWidth="150" promptText="Catégorie" style="-fx-background-radius: 14;"/>
    </HBox>

    <!-- ===== CONTENU SCROLLABLE ===== -->
    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" 
                style="-fx-background-color: white; -fx-background: white; -fx-border-color: transparent;">
        <StackPane>
            <!-- VIEW 1: TOUTES LES FORMATIONS -->
            <VBox fx:id="allFormationsView" spacing="30" style="-fx-padding: 10 0; -fx-background-color: white;">
                <FlowPane fx:id="formationsFlowPane" hgap="20" vgap="20" alignment="TOP_LEFT" style="-fx-background-color: white;">
                    <!-- Les cartes sont injectées ici -->
                </FlowPane>
                
                <Separator/>
                
                <VBox spacing="15">
                    <Label text="Formations à venir" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1F2A33;"/>
                    <HBox spacing="20">
                         <VBox prefWidth="280" spacing="10" 
                               style="-fx-background-color: #F8FBFC; -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: #DDECEF; -fx-border-radius: 15;">
                            <Label text="Psychologie Cognitive" style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                            <Label text="📅 Début : 15 Mars 2026" style="-fx-text-fill: #5C98A8; -fx-font-size: 12px;"/>
                        </VBox>
                        <VBox prefWidth="280" spacing="10" 
                               style="-fx-background-color: #F8FBFC; -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: #DDECEF; -fx-border-radius: 15;">
                            <Label text="Gestion du Stress" style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                            <Label text="📅 Début : 02 Avril 2026" style="-fx-text-fill: #5C98A8; -fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>

            <!-- VIEW 2: MES FORMATIONS -->
            <VBox fx:id="myFormationsView" visible="false" spacing="20" style="-fx-padding: 10 0; -fx-background-color: white;">
                <Label text="Mes inscriptions" 
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1F2A33;"/>
                <FlowPane fx:id="participationsFlowPane" hgap="20" vgap="20" alignment="TOP_LEFT" style="-fx-background-color: white;">
                    <!-- Les participations sont injectées ici -->
                </FlowPane>
                <VBox fx:id="noParticipationsBox" visible="false" alignment="CENTER" spacing="15" style="-fx-padding: 60 0; -fx-background-color: white;">
                    <Label text="📚" style="-fx-font-size: 54px; -fx-text-fill: #5C98A8;"/>
                    <Label text="Vous n'êtes inscrit à aucune formation." 
                           style="-fx-text-fill: #5F7F8B; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                </VBox>
            </VBox>
        </StackPane>
    </ScrollPane>


</VBox>
