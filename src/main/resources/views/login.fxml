<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.LoginController"
      spacing="18"
      alignment="CENTER"
      style="-fx-background-color: white;">

    <padding>
        <Insets top="26" right="30" bottom="26" left="30"/>
    </padding>

    <HBox alignment="CENTER" spacing="10">
        <Label text="🧠" style="-fx-font-size: 34px;"/>
        <Label text="MindCare" style="-fx-font-size: 28px; -fx-font-weight: bold;"/>
    </HBox>

    <Label text="Connexion" style="-fx-font-size: 16px; -fx-text-fill: #444;"/>

    <VBox spacing="10" maxWidth="380">
        <TextField fx:id="emailField" promptText="Email" />
        <PasswordField fx:id="passwordField" promptText="Mot de passe" />

        <Label fx:id="errorLabel" text="" wrapText="true"
               style="-fx-text-fill: #DC2626; -fx-font-size: 12px;"/>

        <Button fx:id="loginButton" text="Se connecter" onAction="#handleLogin"
                style="-fx-background-color: #1a6b7c; -fx-text-fill: white; -fx-padding: 10 16; -fx-background-radius: 8;"/>

        <Label text="Utilise tes 2 comptes de la table users" style="-fx-text-fill:#777; -fx-font-size: 11px;"/>
    </VBox>

</VBox>