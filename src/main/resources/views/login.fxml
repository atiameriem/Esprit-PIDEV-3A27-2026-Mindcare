<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="controllers.LoginController"
           style="-fx-background-color: linear-gradient(to bottom right, #E0F7FA, #F1F5F9);">

    <VBox spacing="20"
          alignment="CENTER"
          maxWidth="420"
          style="-fx-background-color: white;
                 -fx-background-radius: 18;
                 -fx-padding: 35;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0.2, 0, 8);">

        <!-- Logo -->
        <HBox alignment="CENTER" spacing="10">
            <Label text="🧠" style="-fx-font-size: 40px;"/>
            <Label text="MindCare"
                   style="-fx-font-size: 30px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1a6b7c;"/>
        </HBox>

        <Label text="Connexion"
               style="-fx-font-size: 16px;
                      -fx-text-fill: #64748B;"/>

        <!-- Champs -->
        <VBox spacing="14" maxWidth="340">

            <TextField fx:id="emailField"
                       promptText="Email"
                       style="-fx-background-radius: 10;
                              -fx-padding: 10;
                              -fx-border-color: #CBD5E1;
                              -fx-border-radius: 10;" />

            <PasswordField fx:id="passwordField"
                           promptText="Mot de passe"
                           style="-fx-background-radius: 10;
                                  -fx-padding: 10;
                                  -fx-border-color: #CBD5E1;
                                  -fx-border-radius: 10;" />

            <Label fx:id="errorLabel"
                   text=""
                   wrapText="true"
                   style="-fx-text-fill: #DC2626;
                          -fx-font-size: 12px;" />

            <!-- Bouton -->
            <Button fx:id="loginButton"
                    text="Se connecter"
                    onAction="#handleLogin"
                    style="-fx-background-color: #1a6b7c;
                           -fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-padding: 10 16;
                           -fx-background-radius: 10;"
                    prefWidth="340"/>

            <Label text="Utilise tes 2 comptes de la table users"
                   style="-fx-text-fill:#94A3B8;
                          -fx-font-size: 11px;"
                   alignment="CENTER"/>
        </VBox>

    </VBox>

</StackPane>