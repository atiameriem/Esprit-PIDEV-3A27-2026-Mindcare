<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox fx:id="mainVBox" spacing="0"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="controllers.SuivieController">

    <padding><Insets bottom="30" left="30" right="30" top="30"/></padding>

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Label fx:id="lblBienvenue"
                   style="-fx-font-size: 32px; -fx-font-weight: 900; -fx-text-fill: #2D1B69;"
                   text="Hello  ✨"/>
            <Label style="-fx-font-size: 15px; -fx-text-fill: #6B4BA8; -fx-font-weight: 600;"
                   text="Tu es sur une super lancée cette semaine ! 🚀"/>
        </VBox>

        <Button fx:id="btnPsychologue"
                onAction="#ouvrirEspacePraticien"
                style="-fx-background-color: #FF6B9D;
                       -fx-text-fill: white;
                       -fx-font-size: 13px;
                       -fx-font-weight: 800;
                       -fx-padding: 12 20 12 20;
                       -fx-background-radius: 20;
                       -fx-border-color: #FF4A7B;
                       -fx-border-radius: 20;
                       -fx-cursor: hand;"
                text="👨‍⚕️ Espace Psy"/>
    </HBox>

    <VBox spacing="0"><padding><Insets top="24"/></padding></VBox>

    <!-- SCORES CIRCULAIRES -->
    <HBox alignment="CENTER" spacing="16">

        <!-- Bien-être -->
        <VBox alignment="CENTER" spacing="10">
            <StackPane>
                <Circle fill="transparent" radius="50" stroke="#E5D4FF" strokeWidth="8"/>
                <Circle fx:id="circleFrancais" fill="transparent" radius="50" stroke="#A78BFA" strokeWidth="8"
                        style="-fx-stroke-dasharray: 314; -fx-stroke-dashoffset: 94;"/>
                <Label fx:id="scoreFrancais" style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #A78BFA;" text="7/10"/>
            </StackPane>
            <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #6B4BA8;" text="Bien-être"/>
        </VBox>

        <!-- Stress -->
        <VBox alignment="CENTER" spacing="10">
            <StackPane>
                <Circle fill="transparent" radius="50" stroke="#FFD4E5" strokeWidth="8"/>
                <Circle fx:id="circleAnglais" fill="transparent" radius="50" stroke="#FF6B9D" strokeWidth="8"
                        style="-fx-stroke-dasharray: 314; -fx-stroke-dashoffset: 157;"/>
                <Label fx:id="scoreAnglais" style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #FF6B9D;" text="5/10"/>
            </StackPane>
            <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #FF6B9D;" text="Stress"/>
        </VBox>

        <!-- Humeur -->
        <VBox alignment="CENTER" spacing="10">
            <StackPane>
                <Circle fill="transparent" radius="50" stroke="#D4F1FF" strokeWidth="8"/>
                <Circle fx:id="circleMaths" fill="transparent" radius="50" stroke="#4FACFE" strokeWidth="8"
                        style="-fx-stroke-dasharray: 314; -fx-stroke-dashoffset: 63;"/>
                <Label fx:id="scoreMaths" style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #4FACFE;" text="8/10"/>
            </StackPane>
            <Label style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #4FACFE;" text="Humeur"/>
        </VBox>

    </HBox>

    <VBox spacing="0"><padding><Insets top="24"/></padding></VBox>

    <!-- Coins gagnés -->
    <HBox alignment="CENTER" spacing="10">
        <Label fx:id="lblCoinsGagnes" text="0 coins"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #6B4BA8;"/>
    </HBox>

    <!-- GRAPHIQUE -->
    <VBox prefHeight="287.0" prefWidth="434.0" spacing="14"
          style="-fx-background-color: white;
                 -fx-background-radius: 28;
                 -fx-padding: 24;
                 -fx-effect: dropshadow(gaussian, rgba(167,139,250,0.25), 16, 0, 0, 6);">

        <HBox alignment="CENTER_LEFT">
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #2D1B69;"
                       text="📊 Progression score par matière"/>
                <Label style="-fx-font-size: 12px; -fx-text-fill: #9CA3AF;"
                       text="Évolution sur les 30 derniers jours"/>
            </VBox>
            <ComboBox fx:id="comboPeriode"
                      style="-fx-background-color: #F3F4F6;
                             -fx-background-radius: 12;
                             -fx-font-size: 12px;
                             -fx-font-weight: 700;
                             -fx-text-fill: #6B7280;"/>
        </HBox>

        <AreaChart fx:id="evolutionChart" animated="true" legendVisible="false" prefHeight="280"
                   style="-fx-background-color: transparent;">
            <xAxis>
                <CategoryAxis tickLabelFill="#9CA3AF"/>
            </xAxis>
            <yAxis>
                <NumberAxis label="" lowerBound="0" tickLabelFill="#9CA3AF" upperBound="10"/>
            </yAxis>
        </AreaChart>

        <HBox alignment="CENTER" spacing="24">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Circle fill="#A78BFA" radius="6"/>
                <Label style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-font-weight: 700;" text="Bien-être"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Circle fill="#FF6B9D" radius="6"/>
                <Label style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-font-weight: 700;" text="Gestion stress"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Circle fill="#4FACFE" radius="6"/>
                <Label style="-fx-font-size: 12px; -fx-text-fill: #6B7280; -fx-font-weight: 700;" text="Humeur"/>
            </HBox>
        </HBox>
    </VBox>

    <VBox spacing="0"><padding><Insets top="20"/></padding></VBox>

    <!-- ACTIONS RAPIDES -->
    <HBox spacing="14"/>

</VBox>
