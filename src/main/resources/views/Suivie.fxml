<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Arc?>
<?import javafx.scene.shape.Circle?>
<?import java.net.URL?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="controllers.SuivieQuizController"
            fitToWidth="true"
            styleClass="scroll-root">

    <!-- ✅ Lien vers le fichier CSS -->
    <stylesheets>
        <URL value="@../styles/suivie-quiz.css"/>
    </stylesheets>

    <VBox spacing="16">
        <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>

        <!-- ═══════ 1. HEADER ═══════════════════════════════════════ -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="lblBienvenue" text="Hello ! ✨"
                       styleClass="lbl-bienvenue"/>
                <Label text="Tu es sur une super lancée cette semaine ! 🚀"
                       styleClass="lbl-sous-titre"/>
            </VBox>
            <Button text="🤖 Assistant IA" onAction="#ouvrirChat"
                    styleClass="btn-assistant"/>
            <Button fx:id="btnEspacePsy" text="👨‍⚕️ Espace Psy"
                    onAction="#ouvrirEspacePraticien"
                    styleClass="btn-espace-psy"/>
        </HBox>

        <HBox>
            <Label fx:id="lblSessionCount" text="0 session complétée"
                   styleClass="badge-session-count"/>
        </HBox>

        <!-- ═══════ 1.5  AVATAR & IDENTITÉ VIRTUELLE ═══════════════ -->
        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="card-lg">

            <!-- Cercle avatar avec halo coloré -->
            <StackPane prefWidth="110" prefHeight="110">
                <Circle fx:id="circleAvatarHalo"
                        centerX="55" centerY="55" radius="54"
                        styleClass="avatar-halo"/>
                <Circle centerX="55" centerY="55" radius="49"
                        styleClass="avatar-cercle"/>
                <ImageView fx:id="imgAvatar"
                           fitWidth="90" fitHeight="90"
                           preserveRatio="true"
                           styleClass="avatar-image"/>
            </StackPane>

            <!-- Infos avatar + état émotionnel -->
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="lblAvatarPseudo"
                           text="Mon Avatar"
                           styleClass="avatar-pseudo"/>
                    <Label fx:id="lblAvatarEtat"
                           text="✨ Chargement..."
                           styleClass="avatar-etat-label"/>
                </HBox>
                <VBox fx:id="avatarEtatBox" spacing="6"
                      styleClass="avatar-etat-box">
                    <Label fx:id="lblAvatarMessage"
                           text="Analyse de votre état en cours..."
                           wrapText="true"
                           styleClass="avatar-message"/>
                </VBox>
            </VBox>

            <!-- Boutons côté droit -->
            <VBox alignment="CENTER" spacing="10">
                <Button fx:id="btnVoixAvatar"
                        text="🔊"
                        onAction="#toggleVoixAvatar"
                        styleClass="btn-voix-active">
                    <tooltip>
                        <Tooltip text="Activer / désactiver la voix de l'avatar"/>
                    </tooltip>
                </Button>
                <Button fx:id="btnPersonnaliserAvatar"
                        text="🎨 Personnaliser"
                        onAction="#personnaliserAvatar"
                        styleClass="btn-personnaliser"/>
            </VBox>
        </HBox>

        <!-- ═══════ 2. SCORES ════════════════════════════════════════ -->
        <HBox alignment="CENTER" spacing="20">

            <!-- Bien-être -->
            <VBox alignment="CENTER" spacing="8" styleClass="score-card">
                <StackPane prefWidth="96" prefHeight="96">
                    <Arc centerX="48" centerY="48" radiusX="40"
                         radiusY="40" startAngle="0" length="360"
                         type="OPEN" styleClass="arc-track-bienetre"/>
                    <Arc fx:id="arcBienEtre" centerX="48" centerY="48"
                         radiusX="40" radiusY="40" startAngle="90"
                         length="0" type="OPEN"
                         styleClass="arc-fill-bienetre"/>
                    <Label fx:id="scoreBienEtre" text="0/100"
                           styleClass="score-value-bienetre"/>
                </StackPane>
                <Label text="Bien-être" styleClass="score-titre-bienetre"/>
                <Label fx:id="lblTrendBienEtre" text="↑ +0%"
                       styleClass="trend-positive"/>
            </VBox>

            <!-- Stress -->
            <VBox alignment="CENTER" spacing="8" styleClass="score-card">
                <StackPane prefWidth="96" prefHeight="96">
                    <Arc centerX="48" centerY="48" radiusX="40"
                         radiusY="40" startAngle="0" length="360"
                         type="OPEN" styleClass="arc-track-stress"/>
                    <Arc fx:id="arcStress" centerX="48" centerY="48"
                         radiusX="40" radiusY="40" startAngle="90"
                         length="0" type="OPEN"
                         styleClass="arc-fill-stress"/>
                    <Label fx:id="scoreStress" text="0/100"
                           styleClass="score-value-stress"/>
                </StackPane>
                <Label text="Stress" styleClass="score-titre-stress"/>
                <Label fx:id="lblTrendStress" text="↓ -0%"
                       styleClass="trend-negative"/>
            </VBox>

            <!-- Humeur -->
            <VBox alignment="CENTER" spacing="8" styleClass="score-card">
                <StackPane prefWidth="96" prefHeight="96">
                    <Arc centerX="48" centerY="48" radiusX="40"
                         radiusY="40" startAngle="0" length="360"
                         type="OPEN" styleClass="arc-track-humeur"/>
                    <Arc fx:id="arcHumeur" centerX="48" centerY="48"
                         radiusX="40" radiusY="40" startAngle="90"
                         length="0" type="OPEN"
                         styleClass="arc-fill-humeur"/>
                    <Label fx:id="scoreHumeur" text="0/100"
                           styleClass="score-value-humeur"/>
                </StackPane>
                <Label text="Humeur" styleClass="score-titre-humeur"/>
                <Label fx:id="lblTrendHumeur" text="↑ +0%"
                       styleClass="trend-positive"/>
            </VBox>

            <!-- Coins -->
            <VBox alignment="CENTER" spacing="6" styleClass="score-card">
                <Label text="🏆" styleClass="coins-emoji"/>
                <Label fx:id="lblCoinsGagnes" text="🪙 0 coins"
                       styleClass="coins-valeur"/>
                <Label text="COINS" styleClass="coins-label"/>
            </VBox>
        </HBox>

        <!-- ═══════ 2.5  🏅 BADGES PAR COINS ══════════════════════ -->
        <VBox fx:id="badgesBox" spacing="14" styleClass="card-lg">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="🏅" styleClass="badge-icone-bg"/>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Mes Badges" styleClass="badges-section-titre"/>
                    <Label text="Débloque des badges en accumulant des coins"
                           styleClass="badges-section-sous"/>
                </VBox>
            </HBox>

            <HBox alignment="CENTER" spacing="8">
                <VBox alignment="CENTER" spacing="4" prefWidth="56">
                    <Label text="🧘" styleClass="palier-emoji"/>
                    <Label text="500"   styleClass="palier-label"/>
                </VBox>
                <Pane HBox.hgrow="ALWAYS" styleClass="palier-separateur"/>
                <VBox alignment="CENTER" spacing="4" prefWidth="56">
                    <Label text="🌤️" styleClass="palier-emoji"/>
                    <Label text="1 500" styleClass="palier-label"/>
                </VBox>
                <Pane HBox.hgrow="ALWAYS" styleClass="palier-separateur"/>
                <VBox alignment="CENTER" spacing="4" prefWidth="56">
                    <Label text="💪" styleClass="palier-emoji"/>
                    <Label text="3 000" styleClass="palier-label"/>
                </VBox>
                <Pane HBox.hgrow="ALWAYS" styleClass="palier-separateur"/>
                <VBox alignment="CENTER" spacing="4" prefWidth="56">
                    <Label text="🔥" styleClass="palier-emoji"/>
                    <Label text="5 000" styleClass="palier-label"/>
                </VBox>
                <Pane HBox.hgrow="ALWAYS" styleClass="palier-separateur"/>
                <VBox alignment="CENTER" spacing="4" prefWidth="56">
                    <Label text="🌈" styleClass="palier-emoji"/>
                    <Label text="8 000" styleClass="palier-label"/>
                </VBox>
            </HBox>

            <Label text="🎯 Complète des sessions pour débloquer tes badges !"
                   styleClass="badges-hint"/>
        </VBox>

        <!-- ═══════ 2.7  🖼️ IMAGE THÉRAPEUTIQUE IA ════════════════ -->
        <VBox spacing="14" styleClass="image-therapeutique-card">

            <!-- En-tête -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="Image Thérapeutique IA"
                           styleClass="image-section-titre"/>
                    <Label fx:id="lblImageMessage"
                           text="Génération en cours selon votre état émotionnel..."
                           wrapText="true"
                           styleClass="image-message"/>
                </VBox>
                <Button fx:id="btnRegeneImage"
                        text="✨ Nouvelle image"
                        onAction="#regenererImage"
                        styleClass="btn-regenere-image"/>
            </HBox>

            <Separator/>

            <!-- Image + overlay chargement -->
            <StackPane alignment="CENTER">

                <!-- L'image générée par IA -->
                <ImageView fx:id="imgTherapeutique"
                           fitWidth="340" fitHeight="210"
                           preserveRatio="true"
                           styleClass="image-therapeutique"/>

                <!-- Overlay affiché pendant la génération -->
                <StackPane fx:id="paneImageLoading"
                           prefWidth="340" prefHeight="210"
                           visible="true"
                           styleClass="image-loading-overlay">
                    <VBox alignment="CENTER" spacing="10">
                        <Label text="🌸" style="-fx-font-size:32px;"/>
                        <Label text="Génération en cours..."
                               style="-fx-font-size:13px; -fx-font-weight:700;
                                      -fx-text-fill:#7C3AED;"/>
                        <Label text="Image thérapeutique IA"
                               style="-fx-font-size:11px; -fx-text-fill:#94a3b8;"/>
                    </VBox>
                </StackPane>
            </StackPane>

            <!-- Badge thème (couleur injectée dynamiquement) -->
            <HBox alignment="CENTER_LEFT">
                <Label fx:id="lblImageTheme"
                       text=""
                       styleClass="image-theme-badge"/>
            </HBox>

        </VBox>

        <!-- ═══════ 3. GRAPHIQUE ═════════════════════════════════════ -->
        <VBox spacing="12" styleClass="card">
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="📊 Progression score"
                           styleClass="graphique-titre"/>
                    <Label text="Évolution dans le temps par session"
                           styleClass="graphique-sous"/>
                </VBox>
                <ComboBox fx:id="comboPeriode" styleClass="combo-periode"/>
            </HBox>

            <AreaChart fx:id="evolutionChart" animated="true"
                       legendVisible="false" prefHeight="190"
                       styleClass="evolution-chart">
                <xAxis>
                    <CategoryAxis tickLabelFill="#9CA3AF"
                                  style="-fx-font-size:11px;"/>
                </xAxis>
                <yAxis>
                    <NumberAxis lowerBound="0" upperBound="100" tickUnit="20"
                                tickLabelFill="#9CA3AF"
                                style="-fx-font-size:11px;"/>
                </yAxis>
            </AreaChart>

            <HBox alignment="CENTER" spacing="24">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Circle fill="#A78BFA" radius="5"/>
                    <Label text="Bien-être" styleClass="legende-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Circle fill="#FF6B9D" radius="5"/>
                    <Label text="Stress" styleClass="legende-label"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Circle fill="#4FACFE" radius="5"/>
                    <Label text="Humeur" styleClass="legende-label"/>
                </HBox>
            </HBox>
        </VBox>

        <!-- ═══════ 4. 🎵 MUSICOTHÉRAPIE ══════════════════════════ -->
        <VBox spacing="14" styleClass="card">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label text="🎵 Musicothérapie IA"
                           styleClass="musique-titre"/>
                    <Label fx:id="lblMusiqueMessage"
                           text="Musique thérapeutique adaptée à votre état"
                           styleClass="musique-sous"/>
                </VBox>
                <Button fx:id="btnChargerMusique"
                        text="🎶 Charger" onAction="#chargerMusique"
                        styleClass="btn-charger-musique"/>
            </HBox>

            <Separator/>

            <VBox fx:id="playerBox" spacing="10" styleClass="player-box">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="lblPisteEmoji" text="🎵"
                           styleClass="piste-emoji-bg"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblPisteNom"
                               text="Aucune piste sélectionnée"
                               styleClass="piste-nom"/>
                        <Label fx:id="lblPisteDuree" text="--"
                               styleClass="piste-duree"/>
                    </VBox>
                    <Label fx:id="lblEtatLecture" text="⏸"
                           styleClass="etat-lecture"/>
                </HBox>

                <HBox alignment="CENTER" spacing="12">
                    <Button text="⏮" onAction="#pistePrecedente"
                            styleClass="btn-nav-piste"/>
                    <Button fx:id="btnPlayPause" text="▶"
                            onAction="#togglePlayPause"
                            styleClass="btn-play-pause"/>
                    <Button text="⏭" onAction="#pisteSuivante"
                            styleClass="btn-nav-piste"/>
                    <Button text="⏹" onAction="#stopMusique"
                            styleClass="btn-stop-piste"/>
                    <Label text="🔊" styleClass="volume-icon"/>
                    <Slider fx:id="sliderVolume" min="0" max="1" value="0.8"
                            prefWidth="80"
                            styleClass="slider-volume"/>
                </HBox>
            </VBox>

            <VBox fx:id="listePistesBox" spacing="6">
                <Label text="🎶 Liste de lecture"
                       styleClass="pistes-liste-titre"/>
                <Label fx:id="lblChargementPistes"
                       text="Cliquez sur 🎶 Charger pour générer votre playlist"
                       styleClass="pistes-hint"/>
            </VBox>
        </VBox>

        <!-- ═══════ 5. CONSEILS PERSONNALISÉS ═══════════════════════ -->
        <VBox spacing="12" styleClass="card">
            <Label text="💡 Conseils personnalisés"
                   styleClass="conseils-titre"/>
            <Label fx:id="lblConseil" wrapText="true"
                   text="Chargement des conseils..."
                   styleClass="conseil-principal"/>
            <Separator/>

            <HBox spacing="10" alignment="TOP_LEFT">
                <Label fx:id="lblEmoji1" text="🧘"
                       styleClass="conseil-emoji-bienetre"/>
                <VBox spacing="2">
                    <Label fx:id="lblTitre1" text="Chargement..."
                           styleClass="conseil-item-titre"/>
                    <Label fx:id="lblDesc1" text="" wrapText="true"
                           styleClass="conseil-item-desc"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="TOP_LEFT">
                <Label fx:id="lblEmoji2" text="😮‍💨"
                       styleClass="conseil-emoji-stress"/>
                <VBox spacing="2">
                    <Label fx:id="lblTitre2" text="Chargement..."
                           styleClass="conseil-item-titre"/>
                    <Label fx:id="lblDesc2" text="" wrapText="true"
                           styleClass="conseil-item-desc"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="TOP_LEFT">
                <Label fx:id="lblEmoji3" text="🌙"
                       styleClass="conseil-emoji-humeur"/>
                <VBox spacing="2">
                    <Label fx:id="lblTitre3" text="Chargement..."
                           styleClass="conseil-item-titre"/>
                    <Label fx:id="lblDesc3" text="" wrapText="true"
                           styleClass="conseil-item-desc"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- ═══════ 6. HISTORIQUE DES SESSIONS ═══════════════════════ -->
        <VBox spacing="10" styleClass="card">
            <Label text="📅 Dernières sessions"
                   styleClass="historique-titre"/>
            <VBox fx:id="historyBox" spacing="0">
                <Label text="Chargement de l'historique..."
                       styleClass="history-hint"/>
            </VBox>
        </VBox>

        <Pane prefHeight="12"/>
    </VBox>

</ScrollPane>
