<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="controllers.SuivieController"
            fitToWidth="true"
            style="-fx-background: linear-gradient(to bottom, #FFE5F1, #E5D4FF, #D4F1FF);
                   -fx-background-color: linear-gradient(to bottom, #FFE5F1, #E5D4FF, #D4F1FF);">

    <VBox fx:id="mainVBox" spacing="16">
        <padding><Insets bottom="20" left="24" right="24" top="20"/></padding>

        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label fx:id="lblBienvenue"
                       style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #2D1B69;"
                       text="Hello ! ✨"/>
                <Label style="-fx-font-size: 13px; -fx-text-fill: #6B4BA8; -fx-font-weight: 600;"
                       text="Tu es sur une super lancée cette semaine ! 🚀"/>
            </VBox>
            <Button fx:id="btnPsychologue"
                    onAction="#ouvrirEspacePraticien"
                    style="-fx-background-color: rgba(255,255,255,0.7);
                           -fx-text-fill: #6B4BA8;
                           -fx-font-size: 12px;
                           -fx-font-weight: 800;
                           -fx-padding: 10 16 10 16;
                           -fx-background-radius: 16;
                           -fx-border-color: rgba(107,75,168,0.2);
                           -fx-border-radius: 16;"
                    text="👨‍⚕️ Espace Psy"/>
        </HBox>

        <!-- SCORES CIRCULAIRES -->
        <HBox alignment="CENTER" spacing="20">
            <VBox alignment="CENTER" spacing="8">
                <StackPane>
                    <Circle fill="transparent" radius="45" stroke="#E5D4FF" strokeWidth="7"/>
                    <Circle fx:id="circleFrancais" fill="transparent" radius="45" stroke="#A78BFA" strokeWidth="7"/>
                    <Label fx:id="scoreFrancais"
                           style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #A78BFA;"
                           text="0/100"/>
                </StackPane>
                <Label style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #6B4BA8;"
                       text="Bien-être"/>
            </VBox>
            <VBox alignment="CENTER" spacing="8">
                <StackPane>
                    <Circle fill="transparent" radius="45" stroke="#FFD4E5" strokeWidth="7"/>
                    <Circle fx:id="circleAnglais" fill="transparent" radius="45" stroke="#FF6B9D" strokeWidth="7"/>
                    <Label fx:id="scoreAnglais"
                           style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #FF6B9D;"
                           text="0/100"/>
                </StackPane>
                <Label style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #FF6B9D;"
                       text="Stress"/>
            </VBox>
            <VBox alignment="CENTER" spacing="8">
                <StackPane>
                    <Circle fill="transparent" radius="45" stroke="#D4F1FF" strokeWidth="7"/>
                    <Circle fx:id="circleMaths" fill="transparent" radius="45" stroke="#4FACFE" strokeWidth="7"/>
                    <Label fx:id="scoreMaths"
                           style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #4FACFE;"
                           text="0/100"/>
                </StackPane>
                <Label style="-fx-font-size: 12px; -fx-font-weight: 700; -fx-text-fill: #4FACFE;"
                       text="Humeur"/>
            </VBox>
            <VBox alignment="CENTER" spacing="6"
                  style="-fx-background-color: rgba(255,255,255,0.7);
                         -fx-background-radius: 16;
                         -fx-padding: 12;
                         -fx-border-color: rgba(255,255,255,0.9);
                         -fx-border-radius: 16;">
                <Label text="🏆" style="-fx-font-size: 24px;"/>
                <Label fx:id="lblCoinsGagnes" text="0 coins"
                       style="-fx-font-size: 14px; -fx-font-weight: 800; -fx-text-fill: #6B4BA8;"/>
            </VBox>
        </HBox>

        <!-- GRAPHIQUE -->
        <VBox spacing="12"
              style="-fx-background-color: white;
                     -fx-background-radius: 20;
                     -fx-padding: 16;">
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-size: 15px; -fx-font-weight: 900; -fx-text-fill: #2D1B69;"
                           text="📊 Progression score"/>
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"
                           text="Évolution sur 30 jours"/>
                </VBox>
                <ComboBox fx:id="comboPeriode"
                          style="-fx-background-color: #F3F4F6;
                                 -fx-background-radius: 10;
                                 -fx-font-size: 11px;"/>
            </HBox>
            <AreaChart fx:id="evolutionChart"
                       animated="true"
                       legendVisible="false"
                       prefHeight="180"
                       style="-fx-background-color: transparent;">
                <xAxis>
                    <CategoryAxis tickLabelFill="#9CA3AF"/>
                </xAxis>
                <yAxis>
                    <NumberAxis lowerBound="0" upperBound="100" tickLabelFill="#9CA3AF"/>
                </yAxis>
            </AreaChart>
            <HBox alignment="CENTER" spacing="20">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Circle fill="#A78BFA" radius="5"/>
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #6B7280; -fx-font-weight: 700;"
                           text="Bien-être"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Circle fill="#FF6B9D" radius="5"/>
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #6B7280; -fx-font-weight: 700;"
                           text="Stress"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Circle fill="#4FACFE" radius="5"/>
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #6B7280; -fx-font-weight: 700;"
                           text="Humeur"/>
                </HBox>
            </HBox>
        </VBox>
        <VBox prefHeight="20"/>
    </VBox>
</ScrollPane>
