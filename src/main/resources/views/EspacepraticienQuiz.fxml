<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="controllers.EspacePraticienQuizController"
        spacing="0"
        style="-fx-background-color: #EDF2F4;">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  TOP BAR — style MindCare (blanc + teal déconnexion)        -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="14"
          style="-fx-background-color: white;
                 -fx-padding: 0 28 0 22;
                 -fx-min-height: 66; -fx-pref-height: 66;
                 -fx-border-color: transparent transparent #DDE6EA transparent;
                 -fx-border-width: 0 0 1 0;
                 -fx-effect: dropshadow(gaussian, rgba(74,124,142,0.10), 12, 0, 0, 3);">

        <!-- ← Retour — tout à gauche, petit -->
        <HBox alignment="CENTER" spacing="4"
              style="-fx-background-color: #EDF6F9; -fx-background-radius: 14;
                     -fx-padding: 5 12; -fx-cursor: hand;
                     -fx-border-color: #C0DDE6; -fx-border-radius: 14; -fx-border-width: 1;">
            <Label text="←" style="-fx-font-size: 10px; -fx-text-fill: #4A7C8E; -fx-font-weight: 800;"/>
            <Hyperlink text="Retour" onAction="#retourSuivie"
                       style="-fx-text-fill: #4A7C8E; -fx-font-size: 10px;
                              -fx-font-weight: 700; -fx-border-color: transparent;
                              -fx-underline: false; -fx-padding: 0;"/>
        </HBox>

        <Pane prefWidth="6"/>

        <!-- Logo MindCare style -->
        <HBox alignment="CENTER" spacing="10">
            <StackPane style="-fx-background-color: #EDF2F4; -fx-background-radius: 8;
                              -fx-min-width: 36; -fx-min-height: 36;
                              -fx-pref-width: 36; -fx-pref-height: 36;">
                <Label text="⬜" style="-fx-font-size: 14px; -fx-text-fill: #4A7C8E;"/>
            </StackPane>
            <Label text="MindCare"
                   style="-fx-font-size: 18px; -fx-font-weight: 900;
                          -fx-text-fill: #1E3A44; -fx-font-family: 'Segoe UI';"/>
        </HBox>

        <Pane HBox.hgrow="ALWAYS"/>

        <!-- Titre de la section -->
        <VBox alignment="CENTER_RIGHT" spacing="1">
            <Label text="Espace Praticien"
                   style="-fx-font-size: 15px; -fx-font-weight: 800;
                          -fx-text-fill: #2C5F6E; -fx-font-family: 'Segoe UI';"/>
            <Label text="Vue d'ensemble de vos patients"
                   style="-fx-font-size: 10px; -fx-text-fill: #8AA8B2; -fx-font-weight: 500;"/>
        </VBox>

        <Pane prefWidth="16"/>

        <!-- Doctor badge -->
        <HBox alignment="CENTER" spacing="10"
              style="-fx-background-color: #EDF6F9; -fx-background-radius: 22;
                     -fx-padding: 8 18; -fx-border-color: #C0DDE6;
                     -fx-border-radius: 22; -fx-border-width: 1;">
            <StackPane style="-fx-background-color: #4A7C8E; -fx-background-radius: 16;
                              -fx-min-width: 32; -fx-min-height: 32;
                              -fx-pref-width: 32; -fx-pref-height: 32;">
                <Label text="Dr" style="-fx-font-size: 11px; -fx-font-weight: 900; -fx-text-fill: white;"/>
            </StackPane>
            <Label fx:id="lblNomPsy" text="Dr. Psychologue"
                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #2C5F6E;"/>
        </HBox>
    </HBox>

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  MAIN SCROLL                                                -->
    <!-- ═══════════════════════════════════════════════════════════ -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background: transparent; -fx-background-color: transparent;
                       -fx-border-color: transparent;">
        <VBox spacing="22" style="-fx-padding: 26 28 36 28; -fx-background-color: #EDF2F4;">

            <!-- ─────────────────────────────────────────────────── -->
            <!--  STATS — palette MindCare : violet / rose / cyan    -->
            <!-- ─────────────────────────────────────────────────── -->
            <HBox spacing="14">

                <!-- Patients — violet MindCare -->
                <VBox HBox.hgrow="ALWAYS" spacing="8" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 20;
                             -fx-padding: 22 20; -fx-min-width: 0;
                             -fx-effect: dropshadow(gaussian, rgba(74,124,142,0.10), 18, 0, 0, 4);
                             -fx-border-color: #EDF2F4; -fx-border-radius: 20; -fx-border-width: 1.5;">
                    <StackPane style="-fx-background-color: linear-gradient(to bottom right,#B39DFF,#7C4DFF);
                                      -fx-background-radius: 14;
                                      -fx-min-width: 180; -fx-pref-width: 180;
                                      -fx-min-height: 60; -fx-pref-height: 60;">
                        <Label text="👥" style="-fx-font-size: 22px;"/>
                    </StackPane>
                    <Label fx:id="lblTotalPatients" text="0"
                           style="-fx-font-size: 34px; -fx-font-weight: 900;
                                  -fx-text-fill: #7C4DFF; -fx-font-family: 'Segoe UI';"/>
                    <Label text="Patients suivis"
                           style="-fx-font-size: 12px; -fx-text-fill: #8AA8B2; -fx-font-weight: 600;"/>
                    <Label text="↑ actifs"
                           style="-fx-font-size: 11px; -fx-text-fill: #7C4DFF;
                                  -fx-font-weight: 700; -fx-background-color: #EDE0FF;
                                  -fx-background-radius: 20; -fx-padding: 3 12;
                                  -fx-border-color: #C4A8FF; -fx-border-radius: 20; -fx-border-width: 1;"/>
                </VBox>

                <!-- Tests — rose/magenta MindCare -->
                <VBox HBox.hgrow="ALWAYS" spacing="8" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 20;
                             -fx-padding: 22 20; -fx-min-width: 0;
                             -fx-effect: dropshadow(gaussian, rgba(74,124,142,0.10), 18, 0, 0, 4);
                             -fx-border-color: #EDF2F4; -fx-border-radius: 20; -fx-border-width: 1.5;">
                    <StackPane style="-fx-background-color: linear-gradient(to bottom right,#FF80C8,#E91E8C);
                                      -fx-background-radius: 14;
                                      -fx-min-width: 180; -fx-pref-width: 180;
                                      -fx-min-height: 60; -fx-pref-height: 60;">
                        <Label text="📊" style="-fx-font-size: 22px;"/>
                    </StackPane>
                    <Label fx:id="lblTestsSemaine" text="0"
                           style="-fx-font-size: 34px; -fx-font-weight: 900;
                                  -fx-text-fill: #E91E8C; -fx-font-family: 'Segoe UI';"/>
                    <Label text="Tests réalisés"
                           style="-fx-font-size: 12px; -fx-text-fill: #8AA8B2; -fx-font-weight: 600;"/>
                    <Label text="↑ +99%"
                           style="-fx-font-size: 11px; -fx-text-fill: #E91E8C;
                                  -fx-font-weight: 700; -fx-background-color: #FFD6EE;
                                  -fx-background-radius: 20; -fx-padding: 3 12;
                                  -fx-border-color: #FFB3DC; -fx-border-radius: 20; -fx-border-width: 1;"/>
                </VBox>

                <!-- Progression — cyan/bleu MindCare -->
                <VBox HBox.hgrow="ALWAYS" spacing="8" alignment="CENTER"
                      style="-fx-background-color: white; -fx-background-radius: 20;
                             -fx-padding: 22 20; -fx-min-width: 0;
                             -fx-effect: dropshadow(gaussian, rgba(74,124,142,0.10), 18, 0, 0, 4);
                             -fx-border-color: #EDF2F4; -fx-border-radius: 20; -fx-border-width: 1.5;">
                    <StackPane style="-fx-background-color: linear-gradient(to bottom right,#80DDEF,#29B6D8);
                                      -fx-background-radius: 14;
                                      -fx-min-width: 180; -fx-pref-width: 180;
                                      -fx-min-height: 60; -fx-pref-height: 60;">
                        <Label text="📈" style="-fx-font-size: 22px;"/>
                    </StackPane>
                    <Label fx:id="lblProgressionMoyenne" text="N/A"
                           style="-fx-font-size: 34px; -fx-font-weight: 900;
                                  -fx-text-fill: #29B6D8; -fx-font-family: 'Segoe UI';"/>
                    <Label text="Progression moyenne"
                           style="-fx-font-size: 12px; -fx-text-fill: #8AA8B2; -fx-font-weight: 600;"/>
                    <Label text="↑ +13%"
                           style="-fx-font-size: 11px; -fx-text-fill: #0099BB;
                                  -fx-font-weight: 700; -fx-background-color: #CCF2FB;
                                  -fx-background-radius: 20; -fx-padding: 3 12;
                                  -fx-border-color: #80DDEF; -fx-border-radius: 20; -fx-border-width: 1;"/>
                </VBox>

            </HBox>

            <!-- ─────────────────────────────────────────────────── -->
            <!--  ONGLETS + RECHERCHE — style MindCare arrondi       -->
            <!-- ─────────────────────────────────────────────────── -->
            <VBox spacing="14"
                  style="-fx-background-color: white; -fx-background-radius: 20;
                         -fx-padding: 18 22;
                         -fx-effect: dropshadow(gaussian, rgba(74,124,142,0.08), 18, 0, 0, 3);
                         -fx-border-color: #EDF2F4; -fx-border-radius: 20; -fx-border-width: 1.5;">

                <HBox spacing="10" alignment="CENTER_LEFT">

                    <Button fx:id="btnTous"
                            text="🏥  Tous les patients"
                            onAction="#afficherTousPatients"
                            style="-fx-background-color: #4A7C8E; -fx-text-fill: white;
                                   -fx-font-size: 13px; -fx-font-weight: 800;
                                   -fx-padding: 10 22; -fx-background-radius: 22;
                                   -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian,rgba(74,124,142,0.35),10,0,0,3);"/>

                    <Button fx:id="btnMesPatients"
                            text="👨‍⚕️  Mes patients"
                            onAction="#afficherMesPatients"
                            style="-fx-background-color: #EDF6F9; -fx-text-fill: #4A7C8E;
                                   -fx-font-size: 13px; -fx-font-weight: 700;
                                   -fx-padding: 10 22; -fx-background-radius: 22;
                                   -fx-border-color: #C0DDE6; -fx-border-radius: 22;
                                   -fx-border-width: 1; -fx-cursor: hand;"/>

                    <Pane HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Divider teal -->
                <Region style="-fx-background-color: linear-gradient(to right,#4A7C8E,#29B6D8,#E91E8C,transparent);
                               -fx-pref-height: 2; -fx-min-height: 2; -fx-background-radius: 2;"/>

                <!-- Search row -->
                <HBox spacing="12" alignment="CENTER">
                    <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="0"
                          style="-fx-background-color: #F5FAFB; -fx-background-radius: 22;
                                 -fx-border-color: #C0DDE6; -fx-border-radius: 22;
                                 -fx-border-width: 1; -fx-padding: 0 18;">
                        <Label text="🔍" style="-fx-font-size: 13px; -fx-text-fill: #8AA8B2;"/>
                        <Pane prefWidth="8"/>
                        <TextField fx:id="fieldRecherche"
                                   promptText="Rechercher un patient…"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: transparent;
                                          -fx-border-color: transparent;
                                          -fx-font-size: 13px; -fx-text-fill: #1E3A44;
                                          -fx-prompt-text-fill: #A8C4CD;
                                          -fx-font-family: 'Segoe UI'; -fx-padding: 11 0;"/>
                    </HBox>

                    <ComboBox fx:id="comboFiltre" prefWidth="170"
                              style="-fx-background-color: #F5FAFB;
                                     -fx-border-color: #C0DDE6; -fx-border-radius: 22;
                                     -fx-background-radius: 22; -fx-font-size: 13px;
                                     -fx-text-fill: #2C5F6E; -fx-font-weight: 600;
                                     -fx-padding: 0 10;"/>
                </HBox>
            </VBox>

            <!-- ─────────────────────────────────────────────────── -->
            <!--  SECTION LABEL                                       -->
            <!-- ─────────────────────────────────────────────────── -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Region style="-fx-background-color: linear-gradient(to bottom,#4A7C8E,#29B6D8);
                               -fx-pref-width: 4; -fx-min-width: 4;
                               -fx-pref-height: 20; -fx-background-radius: 4;"/>
                <Label text="Liste des patients"
                       style="-fx-font-size: 15px; -fx-font-weight: 800;
                              -fx-text-fill: #1E3A44; -fx-font-family: 'Segoe UI';"/>
            </HBox>

            <!-- ─────────────────────────────────────────────────── -->
            <!--  PATIENT LIST                                        -->
            <!-- ─────────────────────────────────────────────────── -->
            <VBox fx:id="listePatients" spacing="12" style="-fx-padding: 0 0 8 0;"/>

        </VBox>
    </ScrollPane>

</VBox>
