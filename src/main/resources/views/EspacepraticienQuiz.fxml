<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  ╔══════════════════════════════════════════════════════════════╗
  ║  Espace Praticien — MindCare Theme                          ║
  ║  Palette : Teal #4A7C8E · Violet #7C4DFF                   ║
  ║             Rose  #E91E8C · Cyan  #29B6D8                   ║
  ╚══════════════════════════════════════════════════════════════╝
-->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.EspacePraticienQuizController"
      spacing="0"
      style="-fx-background-color: #D8E8EE;">

    <!-- ═══════════════════════════════════════════════════════════
         TOP BAR
    ═══════════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="14"
          style="-fx-background-color: white;
                 -fx-padding: 0 28 0 22;
                 -fx-min-height: 68; -fx-pref-height: 68;
                 -fx-border-color: transparent transparent #E2ECF0 transparent;
                 -fx-border-width: 0 0 1 0;
                 -fx-effect: dropshadow(gaussian, rgba(74,124,142,0.08), 10, 0, 0, 3);">

        <!-- ← Retour -->
        <HBox alignment="CENTER" spacing="6"
              style="-fx-background-color: #EDF6F9;
                     -fx-background-radius: 14;
                     -fx-padding: 7 16;
                     -fx-cursor: hand;
                     -fx-border-color: #C0DDE6;
                     -fx-border-radius: 14;
                     -fx-border-width: 1;">
            <Label text="←"
                   style="-fx-font-size: 12px; -fx-text-fill: #4A7C8E; -fx-font-weight: 800;"/>
            <Hyperlink text="Retour" onAction="#retourSuivie"
                       style="-fx-text-fill: #4A7C8E; -fx-font-size: 12px;
                              -fx-font-weight: 700; -fx-border-color: transparent;
                              -fx-underline: false; -fx-padding: 0;"/>
        </HBox>

        <!-- Logo -->
        <Label text="MindCare"
               style="-fx-font-size: 20px; -fx-font-weight: 900;
                      -fx-text-fill: #1E3A44; -fx-font-family: 'Segoe UI';"/>

        <!-- Spacer gauche -->
        <Pane HBox.hgrow="ALWAYS"/>

        <!-- Titre centré -->
        <VBox alignment="CENTER" spacing="2">
            <Label text="Espace Praticien"
                   style="-fx-font-size: 16px; -fx-font-weight: 800;
                          -fx-text-fill: #1E3A44; -fx-font-family: 'Segoe UI';"/>
            <Label text="Vue d'ensemble de vos patients"
                   style="-fx-font-size: 11px; -fx-text-fill: #8AA8B2; -fx-font-weight: 500;"/>
        </VBox>

        <!-- Spacer droit -->
        <Pane HBox.hgrow="ALWAYS"/>

        <!-- Badge Dr -->
        <HBox alignment="CENTER" spacing="12"
              style="-fx-background-color: #EDF6F9;
                     -fx-background-radius: 26;
                     -fx-padding: 8 20;
                     -fx-border-color: #C0DDE6;
                     -fx-border-radius: 26;
                     -fx-border-width: 1;">
            <StackPane style="-fx-background-color: #4A7C8E;
                              -fx-background-radius: 18;
                              -fx-min-width: 36; -fx-min-height: 36;
                              -fx-pref-width: 36; -fx-pref-height: 36;">
                <Label text="Dr"
                       style="-fx-font-size: 12px; -fx-font-weight: 900; -fx-text-fill: white;"/>
            </StackPane>
            <Label fx:id="lblNomPsy" text="Dr. Psychologue"
                   style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: #2C5F6E;"/>
        </HBox>
    </HBox>

    <!-- ═══════════════════════════════════════════════════════════
         SCROLL MAIN
    ═══════════════════════════════════════════════════════════ -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background: transparent;
                       -fx-background-color: transparent;
                       -fx-border-color: transparent;">

        <VBox spacing="20"
              style="-fx-padding: 24 28 36 28; -fx-background-color: #EDF2F6;">

            <!-- ─────────────────────────────────────────────────
                 CARTES STATS
            ───────────────────────────────────────────────── -->
            <HBox spacing="16">

                <!-- Violet — Patients suivis -->
                <VBox HBox.hgrow="ALWAYS" spacing="10" alignment="CENTER"
                      style="-fx-background-color: white;
                             -fx-background-radius: 20;
                             -fx-padding: 24 20 20 20;
                             -fx-min-width: 0;
                             -fx-effect: dropshadow(gaussian, rgba(74,124,142,0.09), 20, 0, 0, 4);
                             -fx-border-color: #E8EFF2;
                             -fx-border-radius: 20;
                             -fx-border-width: 1;">
                    <StackPane style="-fx-background-color: linear-gradient(to bottom right, #A78BFA, #7C4DFF);
                                      -fx-background-radius: 14;
                                      -fx-min-width: 200; -fx-pref-width: 200;
                                      -fx-min-height: 72; -fx-pref-height: 72;">
                        <Label text="👥" style="-fx-font-size: 28px;"/>
                    </StackPane>
                    <Label fx:id="lblTotalPatients" text="0"
                           style="-fx-font-size: 38px; -fx-font-weight: 900;
                                  -fx-text-fill: #7C4DFF; -fx-font-family: 'Segoe UI';"/>
                    <Label text="Patients suivis"
                           style="-fx-font-size: 13px; -fx-text-fill: #8AA8B2; -fx-font-weight: 600;"/>
                    <Label text="↑ actifs"
                           style="-fx-font-size: 11px; -fx-font-weight: 700;
                                  -fx-text-fill: #7C4DFF;
                                  -fx-background-color: #EDE0FF;
                                  -fx-background-radius: 20;
                                  -fx-padding: 4 14;
                                  -fx-border-color: #C4A8FF;
                                  -fx-border-radius: 20;
                                  -fx-border-width: 1;"/>
                </VBox>

                <!-- Rose — Tests réalisés -->
                <VBox HBox.hgrow="ALWAYS" spacing="10" alignment="CENTER"
                      style="-fx-background-color: white;
                             -fx-background-radius: 20;
                             -fx-padding: 24 20 20 20;
                             -fx-min-width: 0;
                             -fx-effect: dropshadow(gaussian, rgba(74,124,142,0.09), 20, 0, 0, 4);
                             -fx-border-color: #E8EFF2;
                             -fx-border-radius: 20;
                             -fx-border-width: 1;">
                    <StackPane style="-fx-background-color: linear-gradient(to bottom right, #F472B6, #E91E8C);
                                      -fx-background-radius: 14;
                                      -fx-min-width: 200; -fx-pref-width: 200;
                                      -fx-min-height: 72; -fx-pref-height: 72;">
                        <Label text="📊" style="-fx-font-size: 28px;"/>
                    </StackPane>
                    <Label fx:id="lblTestsSemaine" text="0"
                           style="-fx-font-size: 38px; -fx-font-weight: 900;
                                  -fx-text-fill: #E91E8C; -fx-font-family: 'Segoe UI';"/>
                    <Label text="Tests réalisés"
                           style="-fx-font-size: 13px; -fx-text-fill: #8AA8B2; -fx-font-weight: 600;"/>
                    <Label text="↑ +99%"
                           style="-fx-font-size: 11px; -fx-font-weight: 700;
                                  -fx-text-fill: #E91E8C;
                                  -fx-background-color: #FFD6EE;
                                  -fx-background-radius: 20;
                                  -fx-padding: 4 14;
                                  -fx-border-color: #FFB3DC;
                                  -fx-border-radius: 20;
                                  -fx-border-width: 1;"/>
                </VBox>

                <!-- Cyan — Progression -->
                <VBox HBox.hgrow="ALWAYS" spacing="10" alignment="CENTER"
                      style="-fx-background-color: white;
                             -fx-background-radius: 20;
                             -fx-padding: 24 20 20 20;
                             -fx-min-width: 0;
                             -fx-effect: dropshadow(gaussian, rgba(74,124,142,0.09), 20, 0, 0, 4);
                             -fx-border-color: #E8EFF2;
                             -fx-border-radius: 20;
                             -fx-border-width: 1;">
                    <StackPane style="-fx-background-color: linear-gradient(to bottom right, #67E8F9, #29B6D8);
                                      -fx-background-radius: 14;
                                      -fx-min-width: 200; -fx-pref-width: 200;
                                      -fx-min-height: 72; -fx-pref-height: 72;">
                        <Label text="📈" style="-fx-font-size: 28px;"/>
                    </StackPane>
                    <Label fx:id="lblProgressionMoyenne" text="N/A"
                           style="-fx-font-size: 38px; -fx-font-weight: 900;
                                  -fx-text-fill: #29B6D8; -fx-font-family: 'Segoe UI';"/>
                    <Label text="Progression moyenne"
                           style="-fx-font-size: 13px; -fx-text-fill: #8AA8B2; -fx-font-weight: 600;"/>
                    <Label text="↑ +13%"
                           style="-fx-font-size: 11px; -fx-font-weight: 700;
                                  -fx-text-fill: #0099BB;
                                  -fx-background-color: #CCF2FB;
                                  -fx-background-radius: 20;
                                  -fx-padding: 4 14;
                                  -fx-border-color: #80DDEF;
                                  -fx-border-radius: 20;
                                  -fx-border-width: 1;"/>
                </VBox>
            </HBox>

            <!-- ─────────────────────────────────────────────────
                 ONGLETS + FILTRES
            ───────────────────────────────────────────────── -->
            <VBox spacing="16"
                  style="-fx-background-color: white;
                         -fx-background-radius: 20;
                         -fx-padding: 20 24;
                         -fx-effect: dropshadow(gaussian, rgba(74,124,142,0.07), 16, 0, 0, 3);
                         -fx-border-color: #E8EFF2;
                         -fx-border-radius: 20;
                         -fx-border-width: 1;">

                <!-- Onglets -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button fx:id="btnTous"
                            text="🛡  Tous les patients"
                            onAction="#afficherTousPatients"
                            style="-fx-background-color: #4A7C8E;
                                   -fx-text-fill: white;
                                   -fx-font-size: 13px; -fx-font-weight: 800;
                                   -fx-padding: 11 24;
                                   -fx-background-radius: 24;
                                   -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian,rgba(74,124,142,0.35),14,0,0,3);"/>

                    <Button fx:id="btnMesPatients"
                            text="👤  Mes patients"
                            onAction="#afficherMesPatients"
                            style="-fx-background-color: white;
                                   -fx-text-fill: #4A7C8E;
                                   -fx-font-size: 13px; -fx-font-weight: 700;
                                   -fx-padding: 11 24;
                                   -fx-background-radius: 24;
                                   -fx-border-color: #C0DDE6;
                                   -fx-border-radius: 24;
                                   -fx-border-width: 1.5;
                                   -fx-cursor: hand;"/>
                </HBox>

                <!-- Barre dégradée -->
                <Region style="-fx-background-color: linear-gradient(to right, #2C5F6E, #29B6D8, #E91E8C, transparent);
                               -fx-pref-height: 2; -fx-min-height: 2;
                               -fx-background-radius: 2;"/>

                <!-- Recherche + filtre -->
                <HBox spacing="12" alignment="CENTER">
                    <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="0"
                          style="-fx-background-color: #F5FAFB;
                                 -fx-background-radius: 24;
                                 -fx-border-color: #C8DDE4;
                                 -fx-border-radius: 24;
                                 -fx-border-width: 1;
                                 -fx-padding: 0 20;">
                        <Label text="🔍"
                               style="-fx-font-size: 14px; -fx-text-fill: #8AA8B2;"/>
                        <Pane prefWidth="10"/>
                        <TextField fx:id="fieldRecherche"
                                   promptText="Rechercher un patient..."
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: transparent;
                                          -fx-border-color: transparent;
                                          -fx-font-size: 13px;
                                          -fx-text-fill: #1E3A44;
                                          -fx-prompt-text-fill: #A8C4CD;
                                          -fx-font-family: 'Segoe UI';
                                          -fx-padding: 12 0;"/>
                    </HBox>

                    <ComboBox fx:id="comboFiltre" prefWidth="175"
                              style="-fx-background-color: white;
                                     -fx-border-color: #C8DDE4;
                                     -fx-border-radius: 24;
                                     -fx-background-radius: 24;
                                     -fx-font-size: 13px;
                                     -fx-text-fill: #2C5F6E;
                                     -fx-font-weight: 600;
                                     -fx-padding: 3 10;"/>
                </HBox>
            </VBox>

            <!-- ─────────────────────────────────────────────────
                 SECTION LABEL
            ───────────────────────────────────────────────── -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Region style="-fx-background-color: linear-gradient(to bottom, #4A7C8E, #29B6D8);
                               -fx-pref-width: 4; -fx-min-width: 4;
                               -fx-pref-height: 22; -fx-background-radius: 4;"/>
                <Label text="Liste des patients"
                       style="-fx-font-size: 16px; -fx-font-weight: 800;
                              -fx-text-fill: #1E3A44; -fx-font-family: 'Segoe UI';"/>
            </HBox>

            <!-- ─────────────────────────────────────────────────
                 LISTE PATIENTS (générée dynamiquement)
            ───────────────────────────────────────────────── -->
            <VBox fx:id="listePatients" spacing="14"
                  style="-fx-padding: 0 0 8 0;"/>

        </VBox>
    </ScrollPane>
</VBox>
