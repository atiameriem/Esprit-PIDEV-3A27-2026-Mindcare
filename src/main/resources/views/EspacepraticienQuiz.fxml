<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.EspacePraticienQuizController"
      spacing="0"
      style="-fx-background-color: #D8E8EE;">

    <!-- ═══════════════════════════════════════════════════════════
         TOP BAR
    ═══════════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="14"
          style="-fx-background-color: white;
                 -fx-padding: 0 28 0 22;
                 -fx-min-height: 62; -fx-pref-height: 62;
                 -fx-border-color: transparent transparent #E2ECF0 transparent;
                 -fx-border-width: 0 0 1 0;
                 -fx-effect: dropshadow(gaussian, rgba(74,124,142,0.08), 10, 0, 0, 3);">

        <Label text="MindCare"
               style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #1E3A44;"/>

        <Pane HBox.hgrow="ALWAYS"/>

        <VBox alignment="CENTER" spacing="1">
            <Label text="Espace Praticien"
                   style="-fx-font-size: 15px; -fx-font-weight: 800; -fx-text-fill: #1E3A44;"/>
            <Label text="Vue d'ensemble de vos patients"
                   style="-fx-font-size: 10px; -fx-text-fill: #8AA8B2; -fx-font-weight: 500;"/>
        </VBox>

        <Pane HBox.hgrow="ALWAYS"/>

        <HBox alignment="CENTER" spacing="10"
              style="-fx-background-color: #EDF6F9;
                     -fx-background-radius: 24;
                     -fx-padding: 7 18;
                     -fx-border-color: #C0DDE6;
                     -fx-border-radius: 24;
                     -fx-border-width: 1;">
            <StackPane style="-fx-background-color: #4A7C8E;
                              -fx-background-radius: 16;
                              -fx-min-width: 32; -fx-min-height: 32;
                              -fx-pref-width: 32; -fx-pref-height: 32;">
                <Label text="Dr"
                       style="-fx-font-size: 11px; -fx-font-weight: 900; -fx-text-fill: white;"/>
            </StackPane>
            <Label fx:id="lblNomPsy" text="Dr. Psychologue"
                   style="-fx-font-size: 13px; -fx-font-weight: 700; -fx-text-fill: #2C5F6E;"/>
        </HBox>
    </HBox>

    <!-- ═══════════════════════════════════════════════════════════
         SCROLL MAIN
    ═══════════════════════════════════════════════════════════ -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background: transparent;
                       -fx-background-color: transparent;
                       -fx-border-color: transparent;">

        <VBox spacing="18"
              style="-fx-padding: 22 26 32 26; -fx-background-color: #EDF2F6;">

            <!-- ─────────────────────────────────────────────────
                 CARTES STATS — compactes et raffinées
            ───────────────────────────────────────────────── -->
            <HBox spacing="14">

                <!-- Violet — Patients suivis -->
                <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="14"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-padding: 16 20;
                             -fx-effect: dropshadow(gaussian, rgba(74,124,142,0.09), 14, 0, 0, 3);
                             -fx-border-color: #E8EFF2;
                             -fx-border-radius: 16;
                             -fx-border-width: 1;">
                    <StackPane style="-fx-background-color: linear-gradient(to bottom right, #A78BFA, #7C4DFF);
                                      -fx-background-radius: 12;
                                      -fx-min-width: 46; -fx-pref-width: 46;
                                      -fx-min-height: 46; -fx-pref-height: 46;">
                        <Label text="👥" style="-fx-font-size: 20px;"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="lblTotalPatients" text="0"
                               style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #7C4DFF;"/>
                        <Label text="Patients suivis"
                               style="-fx-font-size: 11px; -fx-text-fill: #8AA8B2; -fx-font-weight: 600;"/>
                        <Label text="↑ actifs"
                               style="-fx-font-size: 10px; -fx-font-weight: 700;
                                      -fx-text-fill: #7C4DFF;
                                      -fx-background-color: #EDE0FF;
                                      -fx-background-radius: 20;
                                      -fx-padding: 2 10;"/>
                    </VBox>
                </HBox>

                <!-- Rose — Tests réalisés -->
                <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="14"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-padding: 16 20;
                             -fx-effect: dropshadow(gaussian, rgba(74,124,142,0.09), 14, 0, 0, 3);
                             -fx-border-color: #E8EFF2;
                             -fx-border-radius: 16;
                             -fx-border-width: 1;">
                    <StackPane style="-fx-background-color: linear-gradient(to bottom right, #F472B6, #E91E8C);
                                      -fx-background-radius: 12;
                                      -fx-min-width: 46; -fx-pref-width: 46;
                                      -fx-min-height: 46; -fx-pref-height: 46;">
                        <Label text="📊" style="-fx-font-size: 20px;"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="lblTestsSemaine" text="0"
                               style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #E91E8C;"/>
                        <Label text="Tests réalisés"
                               style="-fx-font-size: 11px; -fx-text-fill: #8AA8B2; -fx-font-weight: 600;"/>
                        <Label text="↑ +99%"
                               style="-fx-font-size: 10px; -fx-font-weight: 700;
                                      -fx-text-fill: #E91E8C;
                                      -fx-background-color: #FFD6EE;
                                      -fx-background-radius: 20;
                                      -fx-padding: 2 10;"/>
                    </VBox>
                </HBox>

                <!-- Cyan — Progression -->
                <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="14"
                      style="-fx-background-color: white;
                             -fx-background-radius: 16;
                             -fx-padding: 16 20;
                             -fx-effect: dropshadow(gaussian, rgba(74,124,142,0.09), 14, 0, 0, 3);
                             -fx-border-color: #E8EFF2;
                             -fx-border-radius: 16;
                             -fx-border-width: 1;">
                    <StackPane style="-fx-background-color: linear-gradient(to bottom right, #67E8F9, #29B6D8);
                                      -fx-background-radius: 12;
                                      -fx-min-width: 46; -fx-pref-width: 46;
                                      -fx-min-height: 46; -fx-pref-height: 46;">
                        <Label text="📈" style="-fx-font-size: 20px;"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="lblProgressionMoyenne" text="N/A"
                               style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-text-fill: #29B6D8;"/>
                        <Label text="Progression moyenne"
                               style="-fx-font-size: 11px; -fx-text-fill: #8AA8B2; -fx-font-weight: 600;"/>
                        <Label text="↑ +13%"
                               style="-fx-font-size: 10px; -fx-font-weight: 700;
                                      -fx-text-fill: #0099BB;
                                      -fx-background-color: #CCF2FB;
                                      -fx-background-radius: 20;
                                      -fx-padding: 2 10;"/>
                    </VBox>
                </HBox>

            </HBox>

            <!-- ─────────────────────────────────────────────────
                 ONGLETS + FILTRES
            ───────────────────────────────────────────────── -->
            <VBox spacing="14"
                  style="-fx-background-color: white;
                         -fx-background-radius: 18;
                         -fx-padding: 18 22;
                         -fx-effect: dropshadow(gaussian, rgba(74,124,142,0.07), 14, 0, 0, 3);
                         -fx-border-color: #E8EFF2;
                         -fx-border-radius: 18;
                         -fx-border-width: 1;">

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button fx:id="btnTous"
                            text="🛡  Tous les patients"
                            onAction="#afficherTousPatients"
                            style="-fx-background-color: #4A7C8E;
                                   -fx-text-fill: white;
                                   -fx-font-size: 12px; -fx-font-weight: 800;
                                   -fx-padding: 10 22;
                                   -fx-background-radius: 22;
                                   -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian,rgba(74,124,142,0.35),10,0,0,3);"/>

                    <Button fx:id="btnMesPatients"
                            text="👤  Mes patients"
                            onAction="#afficherMesPatients"
                            style="-fx-background-color: white;
                                   -fx-text-fill: #4A7C8E;
                                   -fx-font-size: 12px; -fx-font-weight: 700;
                                   -fx-padding: 10 22;
                                   -fx-background-radius: 22;
                                   -fx-border-color: #C0DDE6;
                                   -fx-border-radius: 22;
                                   -fx-border-width: 1.5;
                                   -fx-cursor: hand;"/>
                </HBox>

                <Region style="-fx-background-color: linear-gradient(to right, #2C5F6E, #29B6D8, #E91E8C, transparent);
                               -fx-pref-height: 2; -fx-min-height: 2; -fx-background-radius: 2;"/>

                <HBox spacing="12" alignment="CENTER">
                    <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="0"
                          style="-fx-background-color: #F5FAFB;
                                 -fx-background-radius: 22;
                                 -fx-border-color: #C8DDE4;
                                 -fx-border-radius: 22;
                                 -fx-border-width: 1;
                                 -fx-padding: 0 18;">
                        <Label text="🔍" style="-fx-font-size: 13px; -fx-text-fill: #8AA8B2;"/>
                        <Pane prefWidth="8"/>
                        <TextField fx:id="fieldRecherche"
                                   promptText="Rechercher un patient..."
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: transparent;
                                          -fx-border-color: transparent;
                                          -fx-font-size: 13px;
                                          -fx-text-fill: #1E3A44;
                                          -fx-prompt-text-fill: #A8C4CD;
                                          -fx-padding: 11 0;"/>
                    </HBox>

                    <ComboBox fx:id="comboFiltre" prefWidth="165"
                              style="-fx-background-color: white;
                                     -fx-border-color: #C8DDE4;
                                     -fx-border-radius: 22;
                                     -fx-background-radius: 22;
                                     -fx-font-size: 12px;
                                     -fx-text-fill: #2C5F6E;
                                     -fx-font-weight: 600;
                                     -fx-padding: 3 10;"/>
                </HBox>
            </VBox>

            <!-- ─────────────────────────────────────────────────
                 SECTION LABEL
            ───────────────────────────────────────────────── -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Region style="-fx-background-color: linear-gradient(to bottom, #4A7C8E, #29B6D8);
                               -fx-pref-width: 4; -fx-min-width: 4;
                               -fx-pref-height: 20; -fx-background-radius: 4;"/>
                <Label text="Liste des patients"
                       style="-fx-font-size: 15px; -fx-font-weight: 800; -fx-text-fill: #1E3A44;"/>
            </HBox>

            <!-- ─────────────────────────────────────────────────
                 LISTE PATIENTS
            ───────────────────────────────────────────────── -->
            <VBox fx:id="listePatients" spacing="12"
                  style="-fx-padding: 0 0 8 0;"/>

        </VBox>
    </ScrollPane>
</VBox>
