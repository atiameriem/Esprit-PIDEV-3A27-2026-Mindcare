<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx/17" 
           xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="controllers.SeanceViewController"
           style="-fx-background-color: #0B1120;"
           prefWidth="1280" prefHeight="780">

    <!-- Vue de préparation -->
    <VBox fx:id="preparationView" alignment="CENTER" spacing="0" style="-fx-background-color: transparent;">

        <HBox prefHeight="4" style="-fx-background-color: linear-gradient(to right, #38BDF8, #818CF8, #F472B6);"/>

        <VBox alignment="CENTER" spacing="40" VBox.vgrow="ALWAYS" style="-fx-padding: 0 80;">

            <HBox alignment="CENTER">
                <HBox alignment="CENTER" spacing="8"
                      style="-fx-background-color: rgba(239,68,68,0.15); -fx-padding: 8 20; -fx-background-radius: 30; -fx-border-color: rgba(239,68,68,0.4); -fx-border-radius: 30;">
                    <Circle fx:id="liveDot" radius="5" fill="#EF4444"/>
                    <Label text="SÉANCE EN DIRECT" style="-fx-text-fill: #EF4444; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                </HBox>
            </HBox>

            <VBox alignment="CENTER" spacing="12">
                <Label fx:id="seanceTitreLabel" text="Thérapie du soir"
                       style="-fx-font-size: 36px; -fx-font-weight: 900; -fx-text-fill: white;"/>
                <Label fx:id="formationTitreLabel" text="Formation : Gestion de l'anxiété"
                       style="-fx-font-size: 16px; -fx-text-fill: #94A3B8;"/>
            </VBox>

            <HBox alignment="CENTER" spacing="40">
                <VBox alignment="CENTER" spacing="6"
                      style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 20 30; -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 16;">
                    <Label text="📅" style="-fx-font-size: 22px;"/>
                    <Label fx:id="dateLabel" text="27 Fév 2026" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Label text="Date" style="-fx-text-fill: #64748B; -fx-font-size: 11px;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="6"
                      style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 20 30; -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 16;">
                    <Label text="🕐" style="-fx-font-size: 22px;"/>
                    <Label fx:id="heureLabel" text="14:30" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Label text="Heure" style="-fx-text-fill: #64748B; -fx-font-size: 11px;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="6"
                      style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 20 30; -fx-background-radius: 16; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 16;">
                    <Label text="👤" style="-fx-font-size: 22px;"/>
                    <Label fx:id="participantLabel" text="Vous" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Label text="Participant" style="-fx-text-fill: #64748B; -fx-font-size: 11px;"/>
                </VBox>
            </HBox>

            <VBox spacing="10" alignment="CENTER_LEFT" maxWidth="400">
                <Label text="Vérifications avant de rejoindre :"
                       style="-fx-text-fill: #94A3B8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="✅" style="-fx-font-size: 14px;"/>
                    <Label text="Connexion internet active" style="-fx-text-fill: #CBD5E1; -fx-font-size: 13px;"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="🎤" style="-fx-font-size: 14px;"/>
                    <Label text="Micro et caméra activés" style="-fx-text-fill: #CBD5E1; -fx-font-size: 13px;"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="🔇" style="-fx-font-size: 14px;"/>
                    <Label text="Environnement calme" style="-fx-text-fill: #CBD5E1; -fx-font-size: 13px;"/>
                </HBox>
            </VBox>

            <HBox spacing="20" alignment="CENTER">
                <Button text="← Retour aux séances" onAction="#retourSeances"
                        style="-fx-background-color: rgba(255,255,255,0.07); -fx-text-fill: #94A3B8; -fx-font-weight: bold; -fx-padding: 14 28; -fx-background-radius: 12; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 12;"/>
                <Button fx:id="rejoindreBtn" text="📹  Rejoindre la séance" onAction="#rejoindreSeance"
                        style="-fx-background-color: linear-gradient(to right, #38BDF8, #818CF8); -fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 15px; -fx-padding: 16 40; -fx-background-radius: 14; -fx-cursor: hand;"/>
            </HBox>

            <Label text="La séance s'ouvrira dans la même fenêtre MindCare 🎥"
                   style="-fx-text-fill: #475569; -fx-font-size: 11px; -fx-font-style: italic;"/>
        </VBox>

        <HBox prefHeight="4" style="-fx-background-color: linear-gradient(to right, #F472B6, #818CF8, #38BDF8);"/>
    </VBox>

    <!-- Container Jitsi -->
    <VBox fx:id="jitsiContainer" visible="false" style="-fx-background-color: black;">

        <!-- Toolbar -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #161B22; -fx-padding: 8 20; -fx-border-color: #21262D; -fx-border-width: 0 0 1 0;"
              prefHeight="50">
            <Label text="🧠 MindCare"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #00C9A7;"/>
            <Label text="·  Séance en cours"
                   style="-fx-font-size: 13px; -fx-text-fill: #8B949E;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label fx:id="timerLabel" text="00:00"
                   style="-fx-font-family: 'Courier New'; -fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #00C9A7; -fx-background-color: #0D2818; -fx-padding: 4 14; -fx-background-radius: 20;"/>
            <Label text="⬤  EN DIRECT"
                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #F85149; -fx-background-color: #2D1016; -fx-padding: 4 12; -fx-background-radius: 20;"/>
            <Button text="⛶  Plein écran" onAction="#toggleFullscreen"
                    style="-fx-background-color: #21262D; -fx-text-fill: #E6EDF3; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 6 16; -fx-cursor: hand;"/>
            <Button text="📵  Terminer" onAction="#terminerSeance"
                    style="-fx-background-color: #F85149; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 6 16; -fx-cursor: hand;"/>
        </HBox>

        <!-- Zone browser -->
        <StackPane fx:id="browserContainer" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: black;"/>
    </VBox>

</StackPane>