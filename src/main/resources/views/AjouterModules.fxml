<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.AjouterModulesController"
      spacing="20"
      style="-fx-background-color: #F4F6F9;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- ===== TITRE ===== -->
    <Label text="Ajouter des Modules"
           style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <!-- ===== CARTE MODULE ===== -->
    <VBox spacing="15"
          style="-fx-background-color: white;
                 -fx-padding: 20;
                 -fx-background-radius: 12;
                 -fx-effect: dropshadow(gaussian, #DDD, 8, 0, 0, 3);">

        <TextField fx:id="moduleTitreField"
                   promptText="Titre du module"/>

        <TextArea fx:id="moduleDescriptionArea"
                  promptText="Description du module"
                  prefRowCount="2"/>

        <!-- ===== AJOUT CONTENU ===== -->
        <HBox spacing="10">

            <Button text="📄 Ajouter PDF"
                    onAction="#ajouterPDF"/>

            <Button text="🎥 Ajouter Vidéo"
                    onAction="#ajouterVideo"/>

            <Button text="🎧 Ajouter Podcast"
                    onAction="#ajouterPodcast"/>

        </HBox>

        <!-- Liste contenus -->
        <ListView fx:id="contenusListView"
                  prefHeight="120"/>

        <!-- Bouton ajouter module -->
        <Button text="+ Ajouter Module"
                onAction="#ajouterModule"
                style="-fx-background-color: #4CAF50;
                       -fx-text-fill: white;"/>

    </VBox>

    <!-- ===== LISTE MODULES AJOUTÉS ===== -->
    <VBox spacing="10"
          style="-fx-background-color: white;
                 -fx-padding: 20;
                 -fx-background-radius: 12;">

        <Label text="Modules ajoutés"
               style="-fx-font-weight: bold;"/>

        <ListView fx:id="modulesListView"
                  prefHeight="150"/>
    </VBox>

    <!-- ===== BOUTON FINAL ===== -->
    <Button text="Enregistrer la Formation"
            onAction="#saveFormation"
            style="-fx-background-color: #3B82F6;
                   -fx-text-fill: white;
                   -fx-padding: 12;
                   -fx-background-radius: 8;"/>

</VBox>
