<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ProfilControllerQuiz"
            fitToWidth="true"
            prefWidth="520" prefHeight="650"
            style="-fx-background: #EAF3F5;
                   -fx-background-color: #EAF3F5;
                   -fx-border-color: transparent;">

    <VBox spacing="18">
        <padding><Insets top="24" right="26" bottom="28" left="26"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="18"
              style="-fx-background-color: white;
                     -fx-background-radius: 18;
                     -fx-border-color: rgba(92,152,168,0.20);
                     -fx-border-radius: 18;
                     -fx-border-width: 1.2;
                     -fx-padding: 16 20 16 20;
                     -fx-effect: dropshadow(gaussian, rgba(45,110,126,0.07), 10, 0, 0, 2);">

            <!-- PAS DE STYLE — géré par Platform.runLater() dans initialize() -->
            <Button fx:id="btnRetour" text="← Retour" onAction="#handleRetour"/>

            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label fx:id="lblTitrePatient" text="Résultats du patient 📋"
                       style="-fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: #1F2A33;"/>
                <Label text="Détail des scores par quiz"
                       style="-fx-font-size: 12px; -fx-text-fill: #6E8E9A; -fx-font-weight: 600;"/>
            </VBox>
        </HBox>

        <VBox fx:id="containerReponses" spacing="14">
            <Label text="Chargement des résultats..."
                   style="-fx-font-size: 12px; -fx-text-fill: #6E8E9A; -fx-padding: 10;"/>
        </VBox>

        <Pane prefHeight="16"/>
    </VBox>
</ScrollPane>
