<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.PassageQuizController"
      spacing="16"
      style="-fx-background-color: #dce8f0;">

    <padding><Insets top="24" right="30" bottom="24" left="30"/></padding>

    <!-- ══════════════ BOUTON RETOUR ══════════════ -->
    <HBox>
        <Button fx:id="btnRetour"
                text="← Retour"
                onAction="#retourListe"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #2c3e50;
                       -fx-font-size: 13px;
                       -fx-font-weight: bold;
                       -fx-cursor: hand;
                       -fx-padding: 6 0 6 0;"/>
    </HBox>

    <!-- ══════════════ CARTE TITRE QUIZ ══════════════ -->
    <VBox spacing="6"
          style="-fx-background-color: white;
                 -fx-background-radius: 12;
                 -fx-padding: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
        <Label fx:id="labelTitreQuiz"
               text="Titre du quiz"
               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Label fx:id="labelDescriptionQuiz"
               text="Description du quiz"
               style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
    </VBox>

    <!-- ══════════════ LISTE DES QUESTIONS ══════════════ -->
    <ScrollPane fitToWidth="true"
                style="-fx-background: transparent; -fx-background-color: transparent;"
                VBox.vgrow="ALWAYS">
        <VBox fx:id="listeQuestions" spacing="14"
              style="-fx-background-color: transparent;">
            <!-- Questions générées dynamiquement -->
        </VBox>
    </ScrollPane>

    <!-- ══════════════ BOUTON SOUMETTRE ══════════════ -->
    <HBox alignment="CENTER_RIGHT">
        <Button fx:id="btnSoumettre"
                text="Soumettre le test"
                onAction="#soumettreTest"
                style="-fx-background-color: #2c4a6e;
                       -fx-text-fill: white;
                       -fx-font-size: 14px;
                       -fx-font-weight: bold;
                       -fx-padding: 12 30 12 30;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;"/>
    </HBox>

</VBox>
