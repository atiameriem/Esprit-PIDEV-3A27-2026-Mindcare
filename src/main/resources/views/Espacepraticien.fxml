<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="controllers.EspacePraticienController"
        spacing="20"
        style="-fx-background-color: #F3F4F8; -fx-padding: 30;">

    <!-- HEADER -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Hyperlink text="← Retour patient" onAction="#retourSuivie"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Label text="Espace Praticien" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        <Label text="Vue d'ensemble de vos patients"
               style="-fx-text-fill: #9CA3AF; -fx-font-size: 12px;"/>
    </HBox>

    <!-- STATS -->
    <HBox spacing="60" alignment="CENTER">
        <VBox alignment="CENTER" spacing="5">
            <Label text="👥" style="-fx-font-size: 28px;"/>
            <Label fx:id="lblTotalPatients" text="3"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Label text="Patients suivis" style="-fx-text-fill: #9CA3AF;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="5">
            <Label text="📊" style="-fx-font-size: 28px;"/>
            <Label fx:id="lblTestsSemaine" text="8"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Label text="Tests cette semaine" style="-fx-text-fill: #9CA3AF;"/>
        </VBox>

        <VBox alignment="CENTER" spacing="5">
            <Label text="📈" style="-fx-font-size: 28px;"/>
            <Label fx:id="lblProgressionMoyenne" text="+12%"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
            <Label text="Progression moyenne" style="-fx-text-fill: #9CA3AF;"/>
        </VBox>
    </HBox>

    <!-- RECHERCHE -->
    <HBox spacing="10">
        <TextField fx:id="fieldRecherche" promptText="Rechercher un patient..." HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="comboFiltre" prefWidth="120"/>
    </HBox>

    <!-- LISTE -->
    <ScrollPane fitToWidth="true">
        <VBox fx:id="listePatients" spacing="15"/>
    </ScrollPane>

</VBox>
